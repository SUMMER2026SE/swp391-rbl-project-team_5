@startuml
title Sequence Diagram - Refund Worker (process refund transactions via VNPay)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

participant "Timer\n<<Scheduled Job, 60s>>" as Timer
control "RefundWorker\n<<Background Worker>>" as Worker
control "PaymentController\n<<Controller>>" as Payment
control "VnpayUtil\n<<Utility>>" as VnpayUtil
participant "VNPay\n<<Payment Gateway>>" as VNPay
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Timer -> Worker : tick() (runWithJobLease 'refund-reconciliation')
activate Worker

Worker -> Prisma : refundTransaction.findMany({ status:'PENDING' }, include payment, take 20)
activate Prisma
Prisma -> DB : SELECT pending RefundTransaction[]
activate DB
DB --> Prisma : pending[]
deactivate DB
Prisma --> Worker : pending[]
deactivate Prisma

loop for each pending transaction
  Worker -> Prisma : refundTransaction.updateMany({ id, PENDING -> PROCESSING })
  activate Prisma
  Prisma -> DB : UPDATE RefundTransaction PROCESSING
  DB --> Prisma : count
  Prisma --> Worker : claimed
  deactivate Prisma
  alt claimed.count != 1 (already taken)
    Worker -> Worker : continue (skip)
  else Claimed
    alt transaction.payment missing
      Worker -> Prisma : refundTransaction.update({ NEEDS_RECONCILIATION })
      activate Prisma
      Prisma -> DB : UPDATE RefundTransaction NEEDS_RECONCILIATION
      DB --> Prisma : ok
      Prisma --> Worker : ok
      deactivate Prisma
    else Payment present
      Worker -> Payment : refundViaVnpay({ payment, amount, transactionType, requestId })
      activate Payment
      Payment -> VnpayUtil : signRefundData(params, secret)
      activate VnpayUtil
      VnpayUtil --> Payment : vnp_SecureHash
      deactivate VnpayUtil
      Payment -> VNPay : POST VNP_API (refund request, signed)
      activate VNPay
      VNPay --> Payment : { vnp_ResponseCode, vnp_Message }
      deactivate VNPay
      Payment --> Worker : { success, responseCode, message, raw }
      deactivate Payment

      group Prisma transaction
        Worker -> Prisma : refundTransaction.update({ SUCCESS | FAILED, processedAt, rawResponse })
        activate Prisma
        Prisma -> DB : UPDATE RefundTransaction result
        DB --> Prisma : ok
        Prisma --> Worker : ok
        deactivate Prisma
        opt success AND no remaining refund transactions
          Worker -> Prisma : booking.update({ refundRequired:false })
          activate Prisma
          Prisma -> DB : UPDATE Booking refundRequired=false
          DB --> Prisma : ok
          Prisma --> Worker : ok
          deactivate Prisma
        end
      end
    end
  end
end

deactivate Worker
@enduml

