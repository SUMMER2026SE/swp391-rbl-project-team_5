@startuml
title Sequence Diagram - Auth Middleware (protect)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "protect\n<<Auth Middleware>>" as Protect
control "AuthCookie\n<<Utility>>" as AuthCookie
control "JwtUtils\n<<External Library>>" as Jwt
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

== Authentication Middleware ==
Browser -> Protect : (cookie token / Bearer header)
activate Protect

Protect -> Protect : token = cookies[AUTH_COOKIE_NAME] || readBearerToken(req)
activate Protect
Protect --> Protect : token
deactivate Protect

alt No token
  Protect --> Browser : 401 Unauthorized
else Token present
  Protect -> Protect : continue processing
end

Protect -> Jwt : verify(token, JWT_SECRET)
activate Jwt
Jwt --> Protect : decoded
deactivate Jwt

alt Missing userId or sessionId
  Protect --> Browser : 401 Unauthorized (phien khong hop le)
else Payload valid
  Protect -> Protect : continue processing
end

group Promise.all
  Protect -> Prisma : user.findUnique({ where:{ id: userId }, include:{ profile:true } })
  activate Prisma
  Prisma -> DB : SELECT User (+ profile) by id
  activate DB
  DB --> Prisma : user
  deactivate DB
  Prisma --> Protect : user
  deactivate Prisma

  Protect -> Prisma : authSession.findUnique({ where:{ id: sessionId } })
  activate Prisma
  Prisma -> DB : SELECT AuthSession by id
  activate DB
  DB --> Prisma : session
  deactivate DB
  Prisma --> Protect : session
  deactivate Prisma
end

alt User missing or status != ACTIVE
  Protect --> Browser : 401 Unauthorized (tai khoan bi khoa)
else User active
  Protect -> Protect : continue processing
end

alt Session invalid / revoked / expired / tokenVersion mismatch
  Protect --> Browser : 401 Unauthorized (phien bi thu hoi hoac het han)
else Session valid
  Protect -> Protect : req.user = user; req.authSession = session
end

opt Now - session.lastSeenAt > 5 minutes
  Protect -> Prisma : authSession.updateMany({ where:{ id, revokedAt:null }, data:{ lastSeenAt } })
  activate Prisma
  Prisma -> DB : UPDATE AuthSession SET lastSeenAt
  activate DB
  DB --> Prisma : count
  deactivate DB
  Prisma --> Protect : result
  deactivate Prisma
end

Protect -> Protect : next()
deactivate Protect
@enduml

@startuml
title Sequence Diagram - Register Account

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "AuthRoutes\n<<Express Router>>" as AuthRoutes
control "authRateLimit\n<<Rate Limit Middleware>>" as RateLimit
control "AuthController\n<<Controller>>" as Auth
control "Validators\n<<Utility>>" as Validators
control "Bcrypt\n<<External Library>>" as Bcrypt
control "TokenUtils\n<<Utility>>" as TokenUtils
control "Mailer\n<<Email Service>>" as Mailer
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> AuthRoutes : POST /api/auth/register\nbody: fullName, email, password, phoneNumber
activate AuthRoutes
AuthRoutes -> RateLimit : authRateLimit(req)
activate RateLimit
alt Rate limit exceeded
  RateLimit --> Browser : 429 Too Many Requests
else Within limit
  RateLimit --> AuthRoutes : next()
end
deactivate RateLimit
AuthRoutes -> Auth : register(req, res, next)
activate Auth

== Input Validation ==
Auth -> Auth : normalize fullName / email / password / phoneNumber
activate Auth
Auth --> Auth : normalized inputs
deactivate Auth

Auth -> Validators : validateFullName(fullName)
activate Validators
Validators --> Auth : error message | ''
deactivate Validators
alt Invalid fullName
  Auth --> Browser : 400 Bad Request
else fullName valid
  Auth -> Auth : continue processing
end

alt Missing email or password
  Auth --> Browser : 400 Bad Request
else Present
  Auth -> Auth : continue processing
end

Auth -> Validators : isValidEmail(email)
activate Validators
Validators --> Auth : boolean
deactivate Validators
alt Invalid email
  Auth --> Browser : 400 Bad Request
else Valid email
  Auth -> Auth : continue processing
end

Auth -> Validators : isValidPhoneNumber(phoneNumber)
activate Validators
Validators --> Auth : boolean
deactivate Validators
alt Invalid phone number
  Auth --> Browser : 400 Bad Request
else Valid phone
  Auth -> Auth : continue processing
end

Auth -> Validators : validatePassword(password)
activate Validators
Validators --> Auth : error message | ''
deactivate Validators
alt Weak password
  Auth --> Browser : 400 Bad Request
else Password valid
  Auth -> Auth : continue processing
end

== Business Logic ==
Auth -> Prisma : user.findUnique({ where:{ email } })
activate Prisma
Prisma -> DB : SELECT User by email
activate DB
DB --> Prisma : existingUser | null
deactivate DB
Prisma --> Auth : existingUser
deactivate Prisma
alt Email already used
  Auth --> Browser : 409 Conflict
else Email available
  Auth -> Auth : continue processing
end

Auth -> Bcrypt : hash(password, SALT_ROUNDS)
activate Bcrypt
Bcrypt --> Auth : passwordHash
deactivate Bcrypt

== Database Operation ==
group Prisma transaction
  Auth -> Prisma : tx.user.create({ data: {...user, profile:{create:{phoneNumber}} } })
  activate Prisma
  Prisma -> DB : INSERT User + UserProfile
  activate DB
  DB --> Prisma : createdUser
  deactivate DB
  Prisma --> Auth : createdUser
  deactivate Prisma

  Auth -> Prisma : tx.emailVerificationToken.deleteMany({ where:{ userId } })
  activate Prisma
  Prisma -> DB : DELETE old EmailVerificationToken
  activate DB
  DB --> Prisma : count
  deactivate DB
  Prisma --> Auth : result
  deactivate Prisma

  Auth -> TokenUtils : createRandomToken()
  activate TokenUtils
  TokenUtils --> Auth : verificationToken
  deactivate TokenUtils
  Auth -> TokenUtils : hashToken(verificationToken)
  activate TokenUtils
  TokenUtils --> Auth : tokenHash
  deactivate TokenUtils
  Auth -> TokenUtils : addMinutes(TOKEN_EXPIRY_MINUTES)
  activate TokenUtils
  TokenUtils --> Auth : expiresAt
  deactivate TokenUtils

  Auth -> Prisma : tx.emailVerificationToken.create({ data:{ userId, token, expiresAt } })
  activate Prisma
  Prisma -> DB : INSERT EmailVerificationToken
  activate DB
  DB --> Prisma : token row
  deactivate DB
  Prisma --> Auth : verificationToken row
  deactivate Prisma
end

== External Service ==
Auth -> Mailer : sendVerificationEmail({ to: email, token })
activate Mailer
Mailer --> Auth : send result
deactivate Mailer

== Response ==
Auth -> Auth : sanitizeUser(user)
Auth --> Browser : 201 Created { message, user }
deactivate Auth
deactivate AuthRoutes
@enduml

