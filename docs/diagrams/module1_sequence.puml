title Sequence Diagram - Logout (POST /api/auth/logout)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "AuthRoutes\n<<Express Router>>" as AuthRoutes
control "protect\n<<Auth Middleware>>" as Protect
control "AuthController\n<<Controller>>" as Auth
control "AuthCookie\n<<Utility>>" as AuthCookie
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> AuthRoutes : POST /api/auth/logout\ncookie: token
activate AuthRoutes
AuthRoutes -> Protect : protect(req, res, next)
activate Protect
ref over Protect, DB : protect middleware (see Auth Middleware diagram)
Protect --> AuthRoutes : next() (req.authSession set)
deactivate Protect

AuthRoutes -> Auth : logout(req, res, next)
activate Auth
opt req.authSession?.id exists
  Auth -> Prisma : authSession.updateMany({ where:{ id, revokedAt:null }, data:{ revokedAt } })
  activate Prisma
  Prisma -> DB : UPDATE AuthSession SET revokedAt
  activate DB
  DB --> Prisma : count
  deactivate DB
  Prisma --> Auth : result
  deactivate Prisma
end

Auth -> AuthCookie : clearAuthCookie(res)
activate AuthCookie
AuthCookie --> Auth : clear Set-Cookie
deactivate AuthCookie

Auth --> Browser : 200 OK { message }
deactivate Auth
deactivate AuthRoutes
@enduml

