@startuml
title Sequence Diagram - Login (email + password)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "AuthRoutes\n<<Express Router>>" as AuthRoutes
control "authRateLimit\n<<Rate Limit Middleware>>" as RateLimit
control "AuthController\n<<Controller>>" as Auth
control "Validators\n<<Utility>>" as Validators
control "Bcrypt\n<<External Library>>" as Bcrypt
control "AuthSessionUtil\n<<Utility>>" as SessionUtil
control "GenerateToken\n<<Utility>>" as GenToken
control "JwtUtils\n<<External Library>>" as Jwt
control "TokenUtils\n<<Utility>>" as TokenUtils
control "AuthCookie\n<<Utility>>" as AuthCookie
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> AuthRoutes : POST /api/auth/login\nbody: email, password
activate AuthRoutes
AuthRoutes -> RateLimit : authRateLimit(req)
activate RateLimit
RateLimit --> AuthRoutes : next()
deactivate RateLimit
AuthRoutes -> Auth : login(req, res, next)
activate Auth

== Input Validation ==
alt Missing email or password
  Auth --> Browser : 400 Bad Request
else Present
  Auth -> Auth : continue processing
end

Auth -> Validators : isValidEmail(email)
activate Validators
Validators --> Auth : boolean
deactivate Validators
alt Invalid email
  Auth --> Browser : 400 Bad Request
else Valid email
  Auth -> Auth : continue processing
end

== Business Logic ==
Auth -> Prisma : user.findUnique({ where:{ email }, include:{ profile:true } })
activate Prisma
Prisma -> DB : SELECT User (+ profile) by email
activate DB
DB --> Prisma : user | null
deactivate DB
Prisma --> Auth : user
deactivate Prisma

alt User missing or no passwordHash
  Auth --> Browser : 401 Unauthorized
else User has password
  Auth -> Auth : continue processing
end

alt status != ACTIVE
  Auth --> Browser : 403 Forbidden (tai khoan bi khoa)
else Active
  Auth -> Auth : continue processing
end

Auth -> Bcrypt : compare(password, user.passwordHash)
activate Bcrypt
Bcrypt --> Auth : passwordMatches
deactivate Bcrypt
alt Password does not match
  Auth --> Browser : 401 Unauthorized
else Password matches
  Auth -> Auth : continue processing
end

alt Email not verified
  Auth --> Browser : 403 Forbidden { message, code: EMAIL_NOT_VERIFIED }
else Email verified
  Auth -> Auth : continue processing
end

== Session Creation ==
Auth -> SessionUtil : createAuthSession(req, user)
activate SessionUtil
SessionUtil -> GenToken : generateToken(user, sessionId)
activate GenToken
GenToken -> Jwt : sign({ userId, sessionId, tokenVersion }, JWT_SECRET)
activate Jwt
Jwt --> GenToken : token
deactivate Jwt
GenToken --> SessionUtil : token
deactivate GenToken
SessionUtil -> Jwt : decode(token)
activate Jwt
Jwt --> SessionUtil : decoded (exp)
deactivate Jwt
SessionUtil -> TokenUtils : hashToken(token)
activate TokenUtils
TokenUtils --> SessionUtil : tokenHash
deactivate TokenUtils
SessionUtil -> Prisma : authSession.create({ data:{ id, userId, tokenHash, userAgent, ipAddress, expiresAt, lastSeenAt } })
activate Prisma
Prisma -> DB : INSERT AuthSession
activate DB
DB --> Prisma : session
deactivate DB
Prisma --> SessionUtil : session
deactivate Prisma
SessionUtil --> Auth : { session, token }
deactivate SessionUtil

Auth -> AuthCookie : setAuthCookie(res, token)
activate AuthCookie
AuthCookie --> Auth : Set-Cookie(token)
deactivate AuthCookie

== Response ==
Auth -> Auth : sanitizeUser(user)
Auth --> Browser : 200 OK { message, user }
deactivate Auth
deactivate AuthRoutes
@enduml

@startuml
title Sequence Diagram - Google Login

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "AuthRoutes\n<<Express Router>>" as AuthRoutes
control "authRateLimit\n<<Rate Limit Middleware>>" as RateLimit
control "AuthController\n<<Controller>>" as Auth
control "Validators\n<<Utility>>" as Validators
control "AuthSessionUtil\n<<Utility>>" as SessionUtil
control "AuthCookie\n<<Utility>>" as AuthCookie
participant "Google OAuth\n<<External Provider>>" as GoogleOAuth
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> AuthRoutes : POST /api/auth/google\nbody: credential
activate AuthRoutes
AuthRoutes -> RateLimit : authRateLimit(req)
activate RateLimit
RateLimit --> AuthRoutes : next()
deactivate RateLimit
AuthRoutes -> Auth : googleLogin(req, res, next)
activate Auth

alt Missing credential
  Auth --> Browser : 400 Bad Request
else Credential present
  Auth -> Auth : continue processing
end

Auth -> Auth : verifyGoogleCredential(credential)
activate Auth
alt GOOGLE_CLIENT_ID not configured
  Auth --> Browser : 500 Internal Server Error
else Configured
  Auth -> GoogleOAuth : verifyIdToken({ idToken, audience })
  activate GoogleOAuth
  GoogleOAuth --> Auth : ticket payload (email, name, picture, sub)
  deactivate GoogleOAuth
end
Auth --> Auth : { email, fullName, avatarUrl, providerAccountId }
deactivate Auth

Auth -> Validators : isValidEmail(email)
activate Validators
Validators --> Auth : boolean
deactivate Validators
alt Invalid Google email
  Auth --> Browser : 400 Bad Request
else Valid email
  Auth -> Auth : continue processing
end

Auth -> Validators : isValidAvatarUrl(avatarUrl)
activate Validators
Validators --> Auth : boolean
deactivate Validators
alt Invalid avatar URL
  Auth --> Browser : 400 Bad Request
else Valid avatar
  Auth -> Auth : continue processing
end

Auth -> Prisma : user.findUnique({ where:{ email }, include:{ profile:true } })
activate Prisma
Prisma -> DB : SELECT User (+ profile) by email
activate DB
DB --> Prisma : user | null
deactivate DB
Prisma --> Auth : user
deactivate Prisma

alt User not found
  Auth -> Prisma : user.create({ data:{ email, fullName, provider:GOOGLE, isEmailVerified:true, profile:{create}, oauthAccounts:{create} } })
  activate Prisma
  Prisma -> DB : INSERT User + UserProfile + OAuthAccount
  activate DB
  DB --> Prisma : user
  deactivate DB
  Prisma --> Auth : user
  deactivate Prisma
else Existing user
  alt status != ACTIVE
    Auth --> Browser : 403 Forbidden (tai khoan bi khoa)
  else Active
    Auth -> Prisma : user.update({ where:{ id }, data:{ isEmailVerified:true, provider, profile:{upsert} }, include:{ profile:true } })
    activate Prisma
    Prisma -> DB : UPDATE User + upsert UserProfile
    activate DB
    DB --> Prisma : user
    deactivate DB
    Prisma --> Auth : user
    deactivate Prisma

    Auth -> Prisma : oAuthAccount.upsert({ where:{ provider_providerAccountId }, create:{...} })
    activate Prisma
    Prisma -> DB : UPSERT OAuthAccount
    activate DB
    DB --> Prisma : oauthAccount
    deactivate DB
    Prisma --> Auth : result
    deactivate Prisma
  end
end

ref over Auth, DB : createAuthSession(req, user) + setAuthCookie(res, token)\n(see Login diagram - Session Creation)

Auth -> Auth : sanitizeUser(user)
Auth --> Browser : 200 OK { message, user }
deactivate Auth
deactivate AuthRoutes
@enduml

