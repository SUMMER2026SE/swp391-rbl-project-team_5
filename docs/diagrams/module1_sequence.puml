@startuml
title Sequence Diagram - Update Profile (PUT /api/users/profile)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "UserRoutes\n<<Express Router>>" as UserRoutes
control "protect\n<<Auth Middleware>>" as Protect
control "UserController\n<<Controller>>" as User
control "Validators\n<<Utility>>" as Validators
control "AuthController\n<<Controller>>" as Auth
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> UserRoutes : PUT /api/users/profile\nbody: fullName?, phoneNumber?, avatarUrl?, gender?, address?, dateOfBirth?
activate UserRoutes
UserRoutes -> Protect : protect(req, res, next)
activate Protect
ref over Protect, DB : protect middleware (see Auth Middleware diagram)
Protect --> UserRoutes : next() (req.user set)
deactivate Protect

UserRoutes -> User : updateProfile(req, res, next)
activate User

opt fullName provided
  User -> Validators : validateFullName(fullName)
  activate Validators
  Validators --> User : error | ''
  deactivate Validators
  alt Invalid fullName
    User --> Browser : 400 Bad Request
  else Valid
    User -> User : userUpdate.fullName = fullName
  end
end

opt phoneNumber provided
  User -> Validators : isValidPhoneNumber(phoneNumber)
  activate Validators
  Validators --> User : boolean
  deactivate Validators
  alt Invalid phone
    User --> Browser : 400 Bad Request
  else Valid
    User -> User : profileUpdate.phoneNumber = value
  end
end

opt avatarUrl provided
  User -> Validators : isValidAvatarUrl(avatarUrl)
  activate Validators
  Validators --> User : boolean
  deactivate Validators
  alt Invalid avatar URL
    User --> Browser : 400 Bad Request
  else Valid
    User -> User : profileUpdate.avatarUrl = value
  end
end

opt gender provided
  User -> Validators : isValidGender(gender)
  activate Validators
  Validators --> User : boolean
  deactivate Validators
  alt Invalid gender
    User --> Browser : 400 Bad Request
  else Valid
    User -> User : profileUpdate.gender = value
  end
end

opt dateOfBirth provided
  User -> Validators : validateDateOfBirth(value)
  activate Validators
  Validators --> User : error | ''
  deactivate Validators
  alt Invalid date of birth
    User --> Browser : 400 Bad Request (thrown error statusCode 400)
  else Valid
    User -> User : profileUpdate.dateOfBirth = new Date(value)
  end
end

User -> Prisma : user.update({ where:{ id }, data:{ ...userUpdate, profile:{ upsert:{ create, update } } }, include:{ profile:true } })
activate Prisma
Prisma -> DB : UPDATE User + upsert UserProfile
activate DB
DB --> Prisma : updatedUser
deactivate DB
Prisma --> User : updatedUser
deactivate Prisma

User -> Auth : sanitizeUser(updatedUser)
activate Auth
Auth --> User : sanitized user
deactivate Auth
User --> Browser : 200 OK { message, user }
deactivate User
deactivate UserRoutes
@enduml

@startuml
title Sequence Diagram - Upload Avatar (POST /api/users/upload-avatar)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "UserRoutes\n<<Express Router>>" as UserRoutes
control "protect\n<<Auth Middleware>>" as Protect
control "uploadAvatar.single\n<<Multer Middleware>>" as Multer
control "validateUploadedFiles\n<<Upload Middleware>>" as UploadValidate
control "UserController\n<<Controller>>" as User
control "AuthController\n<<Controller>>" as Auth
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> UserRoutes : POST /api/users/upload-avatar\nmultipart: avatar
activate UserRoutes
UserRoutes -> Protect : protect(req, res, next)
activate Protect
ref over Protect, DB : protect middleware (see Auth Middleware diagram)
Protect --> UserRoutes : next() (req.user set)
deactivate Protect

UserRoutes -> Multer : uploadAvatar.single('avatar')
activate Multer
alt Invalid mimetype / size
  Multer --> Browser : 400 Bad Request (chi ho tro JPEG/PNG)
else File accepted
  Multer --> UserRoutes : req.file set
end
deactivate Multer

UserRoutes -> UploadValidate : validateUploadedFiles(req, res, next)
activate UploadValidate
alt File signature mismatch
  UploadValidate -> UploadValidate : removeFiles(files)
  UploadValidate --> Browser : 400 Bad Request (noi dung file khong dung dinh dang)
else Signature valid
  UploadValidate --> UserRoutes : next()
end
deactivate UploadValidate

UserRoutes -> User : uploadAvatar(req, res, next)
activate User
alt No req.file
  User --> Browser : 400 Bad Request
else File present
  User -> User : continue processing
end

User -> Prisma : user.findUnique({ where:{ id }, include:{ profile:true } })
activate Prisma
Prisma -> DB : SELECT User (+ profile) by id
activate DB
DB --> Prisma : existingUser
deactivate DB
Prisma --> User : existingUser
deactivate Prisma

opt old avatar stored under /uploads/
  User -> User : fs.unlink(oldAvatarPath) (non-critical)
end

User -> User : build avatarUrl = baseUrl + /uploads/ + filename
User -> Prisma : user.update({ where:{ id }, data:{ profile:{ upsert:{ create:{avatarUrl}, update:{avatarUrl} } } }, include:{ profile:true } })
activate Prisma
Prisma -> DB : UPDATE User + upsert UserProfile.avatarUrl
activate DB
DB --> Prisma : updatedUser
deactivate DB
Prisma --> User : updatedUser
deactivate Prisma

User -> Auth : sanitizeUser(updatedUser)
activate Auth
Auth --> User : sanitized user
deactivate Auth
User --> Browser : 200 OK { avatarUrl, message, user }
deactivate User
deactivate UserRoutes
@enduml

@startuml
title Sequence Diagram - Change Password (PUT /api/users/change-password)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "UserRoutes\n<<Express Router>>" as UserRoutes
control "protect\n<<Auth Middleware>>" as Protect
control "UserController\n<<Controller>>" as User
control "Validators\n<<Utility>>" as Validators
control "Bcrypt\n<<External Library>>" as Bcrypt
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> UserRoutes : PUT /api/users/change-password\nbody: currentPassword, newPassword
activate UserRoutes
UserRoutes -> Protect : protect(req, res, next)
activate Protect
ref over Protect, DB : protect middleware (see Auth Middleware diagram)
Protect --> UserRoutes : next() (req.user set)
deactivate Protect

UserRoutes -> User : changePassword(req, res, next)
activate User

alt Missing currentPassword or newPassword
  User --> Browser : 400 Bad Request
else Present
  User -> User : continue processing
end

User -> Validators : validatePassword(newPassword)
activate Validators
Validators --> User : error | ''
deactivate Validators
alt Weak new password
  User --> Browser : 400 Bad Request
else Valid
  User -> User : continue processing
end

User -> Prisma : user.findUnique({ where:{ id: req.user.id } })
activate Prisma
Prisma -> DB : SELECT User by id
activate DB
DB --> Prisma : user
deactivate DB
Prisma --> User : user
deactivate Prisma

alt Not LOCAL provider or no passwordHash
  User --> Browser : 400 Bad Request (tai khoan Google khong doi mat khau tai day)
else LOCAL account
  User -> User : continue processing
end

User -> Bcrypt : compare(currentPassword, user.passwordHash)
activate Bcrypt
Bcrypt --> User : passwordMatches
deactivate Bcrypt
alt Current password incorrect
  User --> Browser : 400 Bad Request
else Correct
  User -> User : continue processing
end

User -> Bcrypt : compare(newPassword, user.passwordHash)
activate Bcrypt
Bcrypt --> User : isSamePassword
deactivate Bcrypt
alt New password equals current
  User --> Browser : 400 Bad Request
else Different
  User -> User : continue processing
end

User -> Bcrypt : hash(newPassword, SALT_ROUNDS)
activate Bcrypt
Bcrypt --> User : passwordHash
deactivate Bcrypt

User -> Prisma : user.update({ where:{ id }, data:{ passwordHash } })
activate Prisma
Prisma -> DB : UPDATE User SET passwordHash
activate DB
DB --> Prisma : result
deactivate DB
Prisma --> User : result
deactivate Prisma

note right of User
  Source only updates User.passwordHash.
  It does NOT increment tokenVersion
  and does NOT revoke AuthSession.
end note
User --> Browser : 200 OK { message }
deactivate User
deactivate UserRoutes
@enduml
