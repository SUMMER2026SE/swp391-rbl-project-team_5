@startuml
title 3.2.8 Change Password (VietTicket)
skinparam shadowing false
skinparam defaultFontName Arial
skinparam ActivityBackgroundColor #FDFDFD
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #FFF6DA

|User|
start
:Open /change-password;
repeat :Change password;
  :Enter current password, new password\n(>= 8, letter + digit) + confirm (match);
  :Click Save;
  |System|
  :Validate input (BR-01, BR-02);
  if (Input valid?) then (No)
    |User|
    :Inline validation error;
  else (Yes)
    |System|
    :PUT /api/users/change-password;
    if (Current password correct?) then (No)
      |User|
      :Error toast (wrong current password);
    else (Yes)
      |System|
      :Update password hash;
      :Confirmation toast;
    endif
  endif
repeat while (Retry after error?) is (Yes) not (No)

|System|
stop
@enduml
