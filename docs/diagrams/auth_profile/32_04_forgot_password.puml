@startuml
title 3.2.4 Forgot Password (VietTicket)
skinparam shadowing false
skinparam defaultFontName Arial
skinparam ActivityBackgroundColor #FDFDFD
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #FFF6DA

|User|
start
:Click "Quen mat khau?" -> open /forgot-password;
repeat :Request reset link;
  :Enter email;
  :Click Submit;
  |System|
  :Validate email format (BR-03);
  if (Email valid & exists?) then (No)
    |User|
    :Show error (email not found / send failed);
  else (Yes)
    |System|
    :Create PasswordResetToken (30 min) - BR-08;
    |Notification Service|
    :Email the reset link;
    |System|
    :Success toast (check your email);
  endif
repeat while (Retry after error?) is (Yes) not (No)

|System|
stop
@enduml
