@startuml
title 3.2.5 Reset Password (VietTicket)
skinparam shadowing false
skinparam defaultFontName Arial
skinparam ActivityBackgroundColor #FDFDFD
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #FFF6DA

|User|
start
:Open /reset-password from the email link;
|System|
:Check reset token;
if (Token valid & not expired?) then (No)
  |User|
  :Show "Lien ket khong hop le hoac da het han"\n(reset blocked);
else (Yes)
  |User|
  repeat :Set new password;
    :Enter new password (>= 8, letter + digit)\n+ confirm (must match);
    :Click Submit;
    |System|
    :Validate new password + confirm (BR-01, BR-02);
    if (Input valid?) then (No)
      |User|
      :Show inline error;
    else (Yes)
      |System|
      :POST /api/auth/reset-password;
      :Replace password hash + invalidate sessions\n(tokenVersion++) - BR-08;
      :Success (can sign in with new password);
    endif
  repeat while (Retry after error?) is (Yes) not (No)
endif

|System|
stop
@enduml
