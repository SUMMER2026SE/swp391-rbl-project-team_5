@startuml
title Sequence Diagram - 6.1 List Refund Requests (GET /api/staff/refunds)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "StaffRouter\n<<Express Router>>" as Router
control "protect + restrictTo('STAFF','ADMIN') + requirePlatformStaff\n<<Middleware Chain>>" as Guard
control "StaffController\n<<Controller>>" as Staff
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : GET /api/staff/refunds?status&search&page&limit
activate Router
Router -> Guard : protect -> restrictTo('STAFF','ADMIN') -> requirePlatformStaff
activate Guard
ref over Guard, DB : protect (Module 1) + platform-staff check (ADMIN or STAFF w/o employer)
Guard --> Router : next() (req.user set)
deactivate Guard

Router -> Staff : listRefundRequests(req, res, next)
activate Staff
Staff -> Staff : assertPlatformRefundStaff(req.user)
alt status invalid
  Staff --> Browser : 400 Bad Request
else Valid / empty
  Staff -> Staff : build where { status?, search OR bookingId/name/attraction }
end

group Promise.all
  Staff -> Prisma : refundRequest.findMany({ where }, include booking+transactions, skip, take)
  activate Prisma
  Prisma -> DB : SELECT RefundRequest[] (+ latest transaction + booking chain)
  DB --> Prisma : requests
  Prisma --> Staff : requests
  deactivate Prisma
  Staff -> Prisma : refundRequest.count({ where })
  activate Prisma
  Prisma -> DB : COUNT RefundRequest
  DB --> Prisma : total
  Prisma --> Staff : total
  deactivate Prisma
  Staff -> Prisma : refundRequest.groupBy({ by: status })
  activate Prisma
  Prisma -> DB : GROUP BY status (stat cards)
  DB --> Prisma : statusGroups
  Prisma --> Staff : statusGroups
  deactivate Prisma
end

Staff --> Browser : 200 OK { data, pagination, stats }
deactivate Staff
deactivate Router
@enduml

@startuml
title Sequence Diagram - 6.2 Process Refund Request (PATCH /api/staff/refunds/:refundId)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "StaffRouter\n<<Express Router>>" as Router
control "protect + restrictTo('STAFF','ADMIN') + requirePlatformStaff\n<<Middleware Chain>>" as Guard
control "StaffController\n<<Controller>>" as Staff
control "RefundLifecycleService\n<<Service>>" as RefundSvc
control "PaymentController.refundViaVnpay\n<<Controller>>" as PayCtl
participant "VNPay\n<<Payment Gateway>>" as VNPay
control "Mailer\n<<Email Service>>" as Mailer
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : PATCH /api/staff/refunds/:refundId\nbody: action (APPROVED|REJECTED), staffNotes?
activate Router
Router -> Guard : protect -> restrictTo('STAFF','ADMIN') -> requirePlatformStaff
activate Guard
ref over Guard, DB : platform-staff guard (see 6.1)
Guard --> Router : next()
deactivate Guard

Router -> Staff : processRefundRequest(req, res, next)
activate Staff
Staff -> Staff : assertPlatformRefundStaff(req.user)

== Input Validation ==
alt action not in {APPROVED, REJECTED}
  Staff --> Browser : 400 Bad Request
else REJECTED without staffNotes
  Staff --> Browser : 400 Bad Request (nhap ly do tu choi)
else Valid
  Staff -> Staff : continue processing
end

Staff -> Prisma : refundRequest.findUnique({ id }, include booking+payments+transactions)
activate Prisma
Prisma -> DB : SELECT RefundRequest (+ booking + payments + transactions)
DB --> Prisma : refundRequest | null
Prisma --> Staff : refundRequest
deactivate Prisma
alt Not found
  Staff --> Browser : 404 Not Found
else status != PENDING
  Staff --> Browser : 409 Conflict (khong con cho xu ly)
else REJECTED and mandatory refund
  Staff --> Browser : 400 Bad Request (khong the tu choi hoan bat buoc)
else Processable
  Staff -> Staff : continue processing
end

== Claim (concurrency guard) ==
Staff -> Prisma : refundRequest.updateMany({ PENDING -> PROCESSING, processedById })
activate Prisma
Prisma -> DB : UPDATE RefundRequest PROCESSING
DB --> Prisma : count
Prisma --> Staff : claimed
deactivate Prisma
alt claimed.count != 1 (taken by another staff)
  Staff --> Browser : 409 Conflict
else Claimed
  Staff -> Staff : continue processing
end

alt action == REJECTED
  group Prisma transaction (Serializable)
    Staff -> Prisma : re-check PROCESSING; opt booking REFUND_REQUESTED -> revert status + refundRequired:false
    activate Prisma
    Prisma -> DB : UPDATE Booking (revert) if needed
    DB --> Prisma : ok
    deactivate Prisma
    Staff -> Prisma : refundRequest.update({ REJECTED, staffNotes, processedAt })
    activate Prisma
    Prisma -> DB : UPDATE RefundRequest REJECTED
    DB --> Prisma : updated
    Prisma --> Staff : updated
    deactivate Prisma
  end
  Staff -> Prisma : auditLog.create({ REFUND_REQUEST_REJECTED })
  activate Prisma
  Prisma -> DB : INSERT AuditLog
  Prisma --> Staff : ok
  deactivate Prisma
  Staff -> Mailer : sendRefundStatusEmail(REJECTED) (non-blocking)
  activate Mailer
  Mailer --> Staff : result
  deactivate Mailer
  Staff --> Browser : 200 OK { data: updated }
else action == APPROVED
  Staff -> RefundSvc : findRefundTargetPayment(refundRequest)
  activate RefundSvc
  RefundSvc --> Staff : payment | null
  deactivate RefundSvc
  alt No successful VNPay payment
    Staff --> Browser : 422 Unprocessable (khong tim thay giao dich)
  else Has payment
    Staff -> Staff : continue processing
  end
  alt existing uncertain transaction (PENDING/PROCESSING/NEEDS_RECONCILIATION)
    Staff --> Browser : 202 Accepted { requiresReconciliation:true }
  else No in-flight transaction
    Staff -> RefundSvc : assertRefundCanBeSubmitted(...) -> { requestedAmount, capturedAmount }
    activate RefundSvc
    RefundSvc --> Staff : amounts (transactionType 02 full / 03 partial)
    deactivate RefundSvc
    Staff -> Prisma : refundTransaction.create({ status:'PROCESSING' })
    activate Prisma
    Prisma -> DB : INSERT RefundTransaction (PROCESSING)
    DB --> Prisma : refundTransaction
    Prisma --> Staff : refundTransaction
    deactivate Prisma
    Staff -> PayCtl : refundViaVnpay({ payment, amount, transactionType, requestId })
    activate PayCtl
    PayCtl -> VNPay : POST VNP_API (refund, signed)
    activate VNPay
    VNPay --> PayCtl : { vnp_ResponseCode, vnp_Message }
    deactivate VNPay
    PayCtl --> Staff : gatewayResult
    deactivate PayCtl
    Staff -> RefundSvc : classifyVnpayRefundResult(gatewayResult)
    activate RefundSvc
    RefundSvc --> Staff : outcome (SUCCESS | FAILED | PENDING_RECONCILIATION)
    deactivate RefundSvc
    alt outcome == PENDING_RECONCILIATION (or network uncertain)
      Staff -> Prisma : refundTransaction.update({ NEEDS_RECONCILIATION })
      activate Prisma
      Prisma -> DB : UPDATE RefundTransaction
      Prisma --> Staff : ok
      deactivate Prisma
      Staff --> Browser : 202 Accepted { requiresReconciliation:true }
    else outcome == FAILED
      Staff -> Prisma : refundTransaction.update(FAILED) + refundRequest.update(back PENDING)
      activate Prisma
      Prisma -> DB : UPDATE RefundTransaction FAILED + RefundRequest PENDING
      Prisma --> Staff : ok
      deactivate Prisma
      Staff --> Browser : 502 Bad Gateway (VNPay tu choi)
    else outcome == SUCCESS
      Staff -> Staff : continue to finalize
    end
  end

  group Prisma transaction (Serializable)
    Staff -> RefundSvc : finalizeSuccessfulRefund(tx, ...)
    activate RefundSvc
    RefundSvc -> Prisma : releaseInventory + ticketInstance.updateMany(REFUNDED) + booking.update(REFUNDED) + refundRequest.update(APPROVED)
    activate Prisma
    Prisma -> DB : UPDATE stocks + TicketInstance + Booking + RefundRequest
    DB --> Prisma : ok
    Prisma --> RefundSvc : updated refundRequest
    deactivate Prisma
    RefundSvc --> Staff : updated
    deactivate RefundSvc
  end
  Staff -> Prisma : auditLog.create({ REFUND_REQUEST_APPROVED })
  activate Prisma
  Prisma -> DB : INSERT AuditLog
  Prisma --> Staff : ok
  deactivate Prisma
  Staff -> Mailer : sendRefundStatusEmail(APPROVED) (non-blocking)
  activate Mailer
  Mailer --> Staff : result
  deactivate Mailer
  Staff --> Browser : 200 OK { data: updated }
end
deactivate Staff
deactivate Router
@enduml

@startuml
title Sequence Diagram - 6.2b Reconcile Refund (POST /api/staff/refunds/:refundId/reconcile) [related staff endpoint]

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "StaffRouter\n<<Express Router>>" as Router
control "protect + restrictTo('STAFF','ADMIN') + requirePlatformStaff\n<<Middleware Chain>>" as Guard
control "StaffController\n<<Controller>>" as Staff
control "RefundLifecycleService\n<<Service>>" as RefundSvc
control "PaymentController.queryVnpayTransaction\n<<Controller>>" as PayCtl
participant "VNPay\n<<Payment Gateway>>" as VNPay
control "Mailer\n<<Email Service>>" as Mailer
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : POST /api/staff/refunds/:refundId/reconcile
activate Router
Router -> Guard : platform-staff guard (see 6.1)
activate Guard
Guard --> Router : next()
deactivate Guard

Router -> Staff : reconcileRefundRequest(req, res, next)
activate Staff
Staff -> Staff : assertPlatformRefundStaff(req.user)
Staff -> Prisma : refundRequest.findUnique({ id }, include transactions PROCESSING/NEEDS_RECONCILIATION)
activate Prisma
Prisma -> DB : SELECT RefundRequest (+ transaction + payment)
DB --> Prisma : refundRequest
Prisma --> Staff : refundRequest
deactivate Prisma
alt Not found
  Staff --> Browser : 404 Not Found
else status != PROCESSING
  Staff --> Browser : 409 Conflict (chi don dang xu ly)
else No transaction to reconcile
  Staff --> Browser : 422 Unprocessable
else Reconcilable
  Staff -> PayCtl : queryVnpayTransaction({ payment })
  activate PayCtl
  PayCtl -> VNPay : POST VNP_API (querydr, signed)
  activate VNPay
  VNPay --> PayCtl : { responseCode, transactionStatus }
  deactivate VNPay
  PayCtl --> Staff : queryResult
  deactivate PayCtl
  Staff -> RefundSvc : classifyVnpayReconciliationResult(queryResult, transaction)
  activate RefundSvc
  RefundSvc --> Staff : outcome
  deactivate RefundSvc
end

alt outcome == PENDING_RECONCILIATION
  Staff -> Prisma : refundTransaction.update({ NEEDS_RECONCILIATION, reconciledAt })
  activate Prisma
  Prisma -> DB : UPDATE RefundTransaction
  Prisma --> Staff : ok
  deactivate Prisma
  Staff --> Browser : 202 Accepted { requiresReconciliation:true }
else outcome == FAILED
  group Prisma transaction
    Staff -> Prisma : refundTransaction.update(FAILED) + refundRequest.update(back PENDING)
    activate Prisma
    Prisma -> DB : UPDATE RefundTransaction + RefundRequest
    Prisma --> Staff : ok
    deactivate Prisma
  end
  Staff --> Browser : 200 OK { status:'PENDING' }
else outcome == SUCCESS
  group Prisma transaction (Serializable)
    Staff -> RefundSvc : finalizeSuccessfulRefund(tx, ...)
    activate RefundSvc
    RefundSvc -> Prisma : releaseInventory + tickets REFUNDED + booking REFUNDED + refundRequest APPROVED
    activate Prisma
    Prisma -> DB : UPDATE (finalize refund)
    Prisma --> RefundSvc : updated
    deactivate Prisma
    RefundSvc --> Staff : updated
    deactivate RefundSvc
  end
  Staff -> Prisma : auditLog.create({ REFUND_RECONCILED_SUCCESS })
  activate Prisma
  Prisma -> DB : INSERT AuditLog
  Prisma --> Staff : ok
  deactivate Prisma
  Staff -> Mailer : sendRefundStatusEmail(APPROVED)
  activate Mailer
  Mailer --> Staff : result
  deactivate Mailer
  Staff --> Browser : 200 OK { data: updated }
end
deactivate Staff
deactivate Router
@enduml

@startuml
title Sequence Diagram - 6.3 Reissue Ticket (POST /api/staff/bookings/:bookingId/reissue)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "StaffRouter\n<<Express Router>>" as Router
control "protect + restrictTo('STAFF','ADMIN') + requireActiveEmployer\n<<Middleware Chain>>" as Guard
control "StaffController\n<<Controller>>" as Staff
control "Mailer\n<<Email Service>>" as Mailer
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : POST /api/staff/bookings/:bookingId/reissue
activate Router
Router -> Guard : protect -> restrictTo('STAFF','ADMIN') -> requireActiveEmployer
activate Guard
ref over Guard, DB : protect + employer APPROVED check
Guard --> Router : next()
deactivate Guard

Router -> Staff : reissueTicket(req, res, next)
activate Staff
group Prisma transaction (Serializable)
  Staff -> Prisma : booking.findUnique({ id }, include user + VALID ticketInstances + reservation)
  activate Prisma
  Prisma -> DB : SELECT Booking (+ tickets + attraction)
  DB --> Prisma : booking | null
  Prisma --> Staff : booking
  deactivate Prisma
  alt Booking not found
    Staff --> Browser : 404 Not Found
  else Found
    Staff -> Prisma : assertStaffAttractionAccess -> staffAttractionAssignment.findFirst (unless ADMIN)
    activate Prisma
    Prisma -> DB : SELECT StaffAttractionAssignment
    DB --> Prisma : assignment | null
    Prisma --> Staff : ok | throw 403
    deactivate Prisma
  end
  alt status not in {CONFIRMED, COMPLETED}
    Staff --> Browser : 409 Conflict (chi cap lai don da xac nhan)
  else no VALID ticket instances
    Staff --> Browser : 400 Bad Request (khong con ve hieu luc)
  else Reissuable
    Staff -> Prisma : ticketInstance.updateMany({ VALID -> EXPIRED })
    activate Prisma
    Prisma -> DB : UPDATE old TicketInstance EXPIRED
    Prisma --> Staff : ok
    deactivate Prisma
    Staff -> Prisma : ticketInstance.create x N (new QR tokens, VALID)
    activate Prisma
    Prisma -> DB : INSERT new TicketInstance[]
    DB --> Prisma : newInstances
    Prisma --> Staff : newInstances
    deactivate Prisma
  end
end

Staff -> Mailer : sendReissueTicketEmail({ to, bookingId, newTicketCount }) (non-blocking)
activate Mailer
Mailer --> Staff : result
deactivate Mailer
Staff --> Browser : 200 OK { data: newInstances }
deactivate Staff
deactivate Router
@enduml

@startuml
title Sequence Diagram - 6.4 Lookup Ticket by QR (GET /api/staff/checkin/:token)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "StaffRouter\n<<Express Router>>" as Router
control "protect + restrictTo('STAFF','ADMIN') + requireCheckInEmployer\n<<Middleware Chain>>" as Guard
control "StaffController\n<<Controller>>" as Staff
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

note over Browser, Router
  Read-only lookup at the gate. Does not write DB.
end note

Browser -> Router : GET /api/staff/checkin/:token
activate Router
Router -> Guard : protect -> restrictTo('STAFF','ADMIN') -> requireCheckInEmployer
activate Guard
ref over Guard, DB : protect + employer APPROVED/SUSPENDED check
Guard --> Router : next()
deactivate Guard

Router -> Staff : lookupTicketByQr(req, res, next)
activate Staff
Staff -> Staff : token = normalizeQrToken(param) (strip 'VIETTICKET:')
alt Missing token
  Staff --> Browser : 400 Bad Request
else Token present
  Staff -> Prisma : ticketInstance.findUnique({ qrCodeToken }, include booking + reservation + attraction)
  activate Prisma
  Prisma -> DB : SELECT TicketInstance (+ booking chain)
  DB --> Prisma : instance | null
  Prisma --> Staff : instance
  deactivate Prisma
end
alt Instance not found
  Staff --> Browser : 404 Not Found
else Found
  Staff -> Prisma : assertStaffAttractionAccess -> staffAttractionAssignment.findFirst (unless ADMIN)
  activate Prisma
  Prisma -> DB : SELECT StaffAttractionAssignment
  DB --> Prisma : assignment | null
  Prisma --> Staff : ok | throw 403
  deactivate Prisma
  Staff -> Staff : blockReason = getCheckinBlockReason(instance) (status/date/time checks)
  Staff --> Browser : 200 OK { ...ticket, canCheckIn, blockReason }
end
deactivate Staff
deactivate Router
@enduml

@startuml
title Sequence Diagram - 6.5 Check In Ticket (POST /api/staff/checkin/:token)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "StaffRouter\n<<Express Router>>" as Router
control "protect + restrictTo('STAFF','ADMIN') + requireCheckInEmployer\n<<Middleware Chain>>" as Guard
control "StaffController\n<<Controller>>" as Staff
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : POST /api/staff/checkin/:token
activate Router
Router -> Guard : protect -> restrictTo('STAFF','ADMIN') -> requireCheckInEmployer
activate Guard
ref over Guard, DB : protect + check-in employer guard (see 6.4)
Guard --> Router : next()
deactivate Guard

Router -> Staff : checkInTicket(req, res, next)
activate Staff
Staff -> Staff : token = normalizeQrToken(param)
alt Missing token
  Staff --> Browser : 400 Bad Request
else Token present
  Staff -> Staff : continue processing
end

group Prisma transaction (Serializable)
  Staff -> Prisma : ticketInstance.findUnique({ qrCodeToken }, include booking + reservation + attraction)
  activate Prisma
  Prisma -> DB : SELECT TicketInstance
  DB --> Prisma : instance | null
  Prisma --> Staff : instance
  deactivate Prisma
  alt Instance not found
    Staff --> Browser : 404 Not Found
  else Found
    Staff -> Prisma : assertStaffAttractionAccess (unless ADMIN)
    activate Prisma
    Prisma -> DB : SELECT StaffAttractionAssignment
    DB --> Prisma : ok | throw 403
    deactivate Prisma
  end
  alt getCheckinBlockReason != null (USED/REFUNDED/EXPIRED/wrong day/time)
    Staff --> Browser : 409 Conflict (blockReason)
  else Valid to check in
    Staff -> Prisma : ticketInstance.updateMany({ id, VALID -> USED, checkedInAt, checkedInById })
    activate Prisma
    Prisma -> DB : UPDATE TicketInstance USED (guard status=VALID)
    DB --> Prisma : count
    Prisma --> Staff : updated
    deactivate Prisma
    alt updated.count == 0 (raced by another staff)
      Staff --> Browser : 409 Conflict (vua duoc check-in)
    else Checked in
      Staff -> Prisma : ticketInstance.count({ bookingId, status != USED })
      activate Prisma
      Prisma -> DB : COUNT remaining non-used tickets
      DB --> Prisma : nonUsedCount
      Prisma --> Staff : nonUsedCount
      deactivate Prisma
      opt nonUsedCount == 0 (all tickets used)
        Staff -> Prisma : booking.updateMany({ CONFIRMED -> COMPLETED })
        activate Prisma
        Prisma -> DB : UPDATE Booking COMPLETED
        Prisma --> Staff : ok
        deactivate Prisma
      end
      Staff -> Prisma : auditLog.create({ TICKET_CHECKED_IN })
      activate Prisma
      Prisma -> DB : INSERT AuditLog
      Prisma --> Staff : ok
      deactivate Prisma
    end
  end
end

Staff --> Browser : 200 OK { ...ticket, ticketStatus:'USED', bookingStatus }
deactivate Staff
deactivate Router
@enduml

