@startuml
title Sequence Diagram - 6.8 Admin Replace Staff Assignments (PUT /api/staff/assignments/:staffId)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "StaffRouter\n<<Express Router>>" as Router
control "protect + restrictTo('ADMIN')\n<<Middleware Chain>>" as Guard
control "StaffController\n<<Controller>>" as Staff
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : PUT /api/staff/assignments/:staffId\nbody: attractionIds[]
activate Router
Router -> Guard : protect -> restrictTo('ADMIN')
activate Guard
ref over Guard, DB : protect + ADMIN role check
Guard --> Router : next()
deactivate Guard

Router -> Staff : replaceStaffAssignments(req, res, next)
activate Staff
alt attractionIds not an array
  Staff --> Browser : 400 Bad Request
else Valid array
  Staff -> Staff : continue processing
end

group Prisma transaction
  Staff -> Prisma : user.findUnique({ id: staffId }, select role + employerPartnerId)
  activate Prisma
  Prisma -> DB : SELECT User (+ roles)
  DB --> Prisma : staff | null
  Prisma --> Staff : staff
  deactivate Prisma
  alt Not found or not STAFF
    Staff --> Browser : 404 Not Found
  else No employerPartnerId
    Staff --> Browser : 400 Bad Request (chua thuoc doi tac nao)
  else Valid staff
    Staff -> Prisma : attraction.count({ ids, partnerId=employer, published+ACTIVE+not suspended })
    activate Prisma
    Prisma -> DB : COUNT eligible attractions
    DB --> Prisma : attractionCount
    Prisma --> Staff : attractionCount
    deactivate Prisma
  end
  alt attractionCount != attractionIds.length
    Staff --> Browser : 400 Bad Request (dia diem khong hop le)
  else All eligible
    Staff -> Prisma : staffAttractionAssignment.updateMany({ notIn ids -> revokedAt })
    activate Prisma
    Prisma -> DB : UPDATE revoke removed assignments
    Prisma --> Staff : ok
    deactivate Prisma
    Staff -> Prisma : staffAttractionAssignment.upsert x ids (revive/create)
    activate Prisma
    Prisma -> DB : UPSERT assignments
    Prisma --> Staff : ok
    deactivate Prisma
    Staff -> Prisma : auditLog.create({ STAFF_ASSIGNMENTS_REPLACED })
    activate Prisma
    Prisma -> DB : INSERT AuditLog
    Prisma --> Staff : ok
    deactivate Prisma
  end
end
Staff --> Browser : 200 OK { data:{ staffId, attractionIds } }
deactivate Staff
deactivate Router
@enduml

@startuml
title Sequence Diagram - 6.9 Partner List Staff (GET /api/partners/staff)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "PartnerRouter\n<<Express Router>>" as Router
control "protect + requirePartner + requireApprovedPartner + restrictTo('PARTNER')\n<<Middleware Chain>>" as Guard
control "PartnerStaffController\n<<Controller>>" as PStaff
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : GET /api/partners/staff
activate Router
Router -> Guard : protect -> requirePartner -> requireApprovedPartner -> restrictTo('PARTNER')
activate Guard
ref over Guard, DB : approved-partner + PARTNER role guard
Guard --> Router : next() (req.partner set)
deactivate Guard

Router -> PStaff : listStaff(req, res, next)
activate PStaff
PStaff -> Prisma : user.findMany({ roleMemberships STAFF, employerPartnerId=partner.id }, include assignments)
activate Prisma
Prisma -> DB : SELECT staff users (+ profile + active assignments)
DB --> Prisma : staff[]
Prisma --> PStaff : staff[]
deactivate Prisma
PStaff --> Browser : 200 OK { data: staff.map(toStaffResponse) }
deactivate PStaff
