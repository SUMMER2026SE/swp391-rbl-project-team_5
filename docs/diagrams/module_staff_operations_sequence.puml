activate Staff
Staff -> Prisma : user.findUnique({ id: staffId }, select roleMemberships)
activate Prisma
Prisma -> DB : SELECT User (+ roles)
DB --> Prisma : staff | null
Prisma --> Staff : staff
deactivate Prisma
alt Not found or not a STAFF
  Staff --> Browser : 404 Not Found
