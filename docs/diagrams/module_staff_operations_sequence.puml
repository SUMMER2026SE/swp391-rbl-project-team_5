@startuml
title Sequence Diagram - 6.14 Replace Staff Assignments (PUT /api/partners/staff/:staffId/assignments)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "PartnerRouter\n<<Express Router>>" as Router
control "protect + requirePartner + requireApprovedPartner + restrictTo('PARTNER')\n<<Middleware Chain>>" as Guard
control "PartnerStaffController\n<<Controller>>" as PStaff
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : PUT /api/partners/staff/:staffId/assignments\nbody: attractionIds[]
activate Router
Router -> Guard : approved-partner + PARTNER role guard
activate Guard
Guard --> Router : next() (req.partner set)
deactivate Guard

Router -> PStaff : replaceStaffAssignments(req, res, next)
activate PStaff
alt attractionIds not an array
  PStaff --> Browser : 400 Bad Request
else Valid array
  group Prisma transaction
    PStaff -> Prisma : findOwnedStaff(partnerId, staffId)
    activate Prisma
    Prisma -> DB : SELECT User (STAFF owned)
    DB --> Prisma : staff | null
    Prisma --> PStaff : staff
    deactivate Prisma
    alt Not found / not owned
      PStaff --> Browser : 404 Not Found
    else Found
      opt attractionIds not empty
        PStaff -> Prisma : attraction.count({ ids, partnerId, archivedAt:null })
        activate Prisma
        Prisma -> DB : COUNT owned attractions
        DB --> Prisma : ownedCount
        Prisma --> PStaff : ownedCount
        deactivate Prisma
        alt ownedCount != attractionIds.length
          PStaff --> Browser : 400 Bad Request (dia diem khong thuoc ban)
        else All owned
          PStaff -> PStaff : continue processing
        end
      end
      PStaff -> Prisma : staffAttractionAssignment.updateMany({ notIn ids -> revokedAt })
      activate Prisma
      Prisma -> DB : UPDATE revoke removed
      Prisma --> PStaff : ok
      deactivate Prisma
      PStaff -> Prisma : staffAttractionAssignment.upsert x ids
      activate Prisma
      Prisma -> DB : UPSERT assignments
      Prisma --> PStaff : ok
      deactivate Prisma
      PStaff -> Prisma : auditLog.create({ PARTNER_STAFF_ASSIGNMENTS_REPLACED })
      activate Prisma
      Prisma -> DB : INSERT AuditLog
      Prisma --> PStaff : ok
      deactivate Prisma
    end
  end
  PStaff --> Browser : 200 OK { data:{ staffId, attractionIds } }
end
deactivate PStaff
deactivate Router
@enduml

@startuml
title Sequence Diagram - 6.15 Remove Staff (DELETE /api/partners/staff/:staffId)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "PartnerRouter\n<<Express Router>>" as Router
control "protect + requirePartner + requireApprovedPartner + restrictTo('PARTNER')\n<<Middleware Chain>>" as Guard
control "PartnerStaffController\n<<Controller>>" as PStaff
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

note over Browser, PStaff
  Soft removal: lock account + revoke assignments/sessions.
  No hard delete (preserve check-in history).
end note

Browser -> Router : DELETE /api/partners/staff/:staffId
activate Router
Router -> Guard : approved-partner + PARTNER role guard
activate Guard
Guard --> Router : next() (req.partner set)
deactivate Guard

Router -> PStaff : removeStaff(req, res, next)
activate PStaff
group Prisma transaction
  PStaff -> Prisma : findOwnedStaff(partnerId, staffId)
  activate Prisma
  Prisma -> DB : SELECT User (STAFF owned)
  DB --> Prisma : staff | null
  Prisma --> PStaff : staff
  deactivate Prisma
  alt Not found / not owned
    PStaff --> Browser : 404 Not Found
  else Found
    PStaff -> Prisma : staffAttractionAssignment.updateMany({ revokedAt })
    activate Prisma
    Prisma -> DB : UPDATE revoke all assignments
    Prisma --> PStaff : ok
    deactivate Prisma
    PStaff -> Prisma : user.update({ status:'LOCKED', tokenVersion++ })
    activate Prisma
    Prisma -> DB : UPDATE User LOCKED
    Prisma --> PStaff : ok
    deactivate Prisma
    PStaff -> Prisma : authSession.updateMany({ revokedAt })
    activate Prisma
    Prisma -> DB : UPDATE revoke sessions
    Prisma --> PStaff : ok
    deactivate Prisma
    PStaff -> Prisma : auditLog.create({ PARTNER_STAFF_REMOVED })
    activate Prisma
    Prisma -> DB : INSERT AuditLog
    Prisma --> PStaff : ok
    deactivate Prisma
  end
end
PStaff --> Browser : 200 OK { data:{ staffId } }
deactivate PStaff
deactivate Router
@enduml
