@startuml
title Sequence Diagram - 6.10 Partner Create Staff (POST /api/partners/staff)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "PartnerRouter\n<<Express Router>>" as Router
control "protect + requirePartner + requireApprovedPartner + restrictTo('PARTNER')\n<<Middleware Chain>>" as Guard
control "PartnerStaffController\n<<Controller>>" as PStaff
control "Validators\n<<Utility>>" as Validators
control "TokenUtils\n<<Utility>>" as TokenUtils
control "Mailer\n<<Email Service>>" as Mailer
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : POST /api/partners/staff\nbody: fullName, email, phoneNumber?
activate Router
Router -> Guard : approved-partner + PARTNER role guard
activate Guard
Guard --> Router : next() (req.partner set)
deactivate Guard

Router -> PStaff : createStaff(req, res, next)
activate PStaff
PStaff -> Validators : validateFullName / isValidEmail / isValidPhoneNumber
activate Validators
Validators --> PStaff : validation result
deactivate Validators
alt Invalid fullName / email / phone
  PStaff --> Browser : 400 Bad Request
else Valid
  PStaff -> Prisma : user.findUnique({ where:{ email } })
  activate Prisma
  Prisma -> DB : SELECT User by email
  DB --> Prisma : existing | null
  Prisma --> PStaff : existing
  deactivate Prisma
end
alt Email already used
  PStaff --> Browser : 409 Conflict
else Available
  group Prisma transaction
    PStaff -> Prisma : user.create({ role:'STAFF', employerPartnerId, isEmailVerified:true, passwordHash:null, roleMemberships })
    activate Prisma
    Prisma -> DB : INSERT User (STAFF, no password)
    DB --> Prisma : created
    Prisma --> PStaff : created
    deactivate Prisma
    PStaff -> TokenUtils : createInviteToken(tx, userId) (reuse PasswordResetToken, 48h)
    activate TokenUtils
    TokenUtils -> Prisma : passwordResetToken.deleteMany + create(hashToken)
    activate Prisma
    Prisma -> DB : DELETE old + INSERT PasswordResetToken
    Prisma --> TokenUtils : ok
    deactivate Prisma
    TokenUtils --> PStaff : inviteToken
    deactivate TokenUtils
    PStaff -> Prisma : auditLog.create({ PARTNER_STAFF_CREATED })
    activate Prisma
    Prisma -> DB : INSERT AuditLog
    Prisma --> PStaff : ok
    deactivate Prisma
  end
  PStaff -> Mailer : sendStaffInviteEmail({ to, businessName, token }) (non-blocking)
  activate Mailer
  Mailer --> PStaff : result
  deactivate Mailer
  PStaff --> Browser : 201 Created { data: toStaffResponse(staff) }
end
deactivate PStaff
deactivate Router
@enduml

