@startuml
title Sequence Diagram - 6.12 Change Staff Status (PATCH /api/partners/staff/:staffId/status)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "PartnerRouter\n<<Express Router>>" as Router
control "protect + requirePartner + requireApprovedPartner + restrictTo('PARTNER')\n<<Middleware Chain>>" as Guard
control "PartnerStaffController\n<<Controller>>" as PStaff
control "Mailer\n<<Email Service>>" as Mailer
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : PATCH /api/partners/staff/:staffId/status\nbody: status (ACTIVE | LOCKED)
activate Router
Router -> Guard : approved-partner + PARTNER role guard
activate Guard
Guard --> Router : next() (req.partner set)
deactivate Guard

Router -> PStaff : changeStaffStatus(req, res, next)
activate PStaff
alt status not in {ACTIVE, LOCKED}
  PStaff --> Browser : 400 Bad Request
else Valid status
  PStaff -> Prisma : findOwnedStaff(partnerId, staffId)
  activate Prisma
  Prisma -> DB : SELECT User (STAFF owned)
  DB --> Prisma : staff | null
  Prisma --> PStaff : staff
  deactivate Prisma
end
alt Not found / not owned
  PStaff --> Browser : 404 Not Found
else Found
  opt staff.status != new status
    group Prisma transaction
      PStaff -> Prisma : user.update({ status, tokenVersion++ if LOCKED })
      activate Prisma
      Prisma -> DB : UPDATE User status
      Prisma --> PStaff : ok
      deactivate Prisma
      opt status == LOCKED
        PStaff -> Prisma : authSession.updateMany({ revokedAt }) (revoke sessions)
        activate Prisma
        Prisma -> DB : UPDATE AuthSession revoke
        Prisma --> PStaff : ok
        deactivate Prisma
      end
      PStaff -> Prisma : auditLog.create({ PARTNER_STAFF_LOCKED | UNLOCKED })
      activate Prisma
      Prisma -> DB : INSERT AuditLog
      Prisma --> PStaff : ok
      deactivate Prisma
    end
    PStaff -> Mailer : sendAccountStatusEmail({ to, status }) (non-blocking)
    activate Mailer
    Mailer --> PStaff : result
    deactivate Mailer
  end
  PStaff -> Prisma : findOwnedStaff (refresh)
  activate Prisma
  Prisma -> DB : SELECT User (fresh)
  DB --> Prisma : fresh
  Prisma --> PStaff : fresh
  deactivate Prisma
  PStaff --> Browser : 200 OK { data: toStaffResponse(fresh) }
end
deactivate PStaff
deactivate Router
@enduml

