@startuml
title Sequence Diagram - 3.11 Upload Attraction Images (POST /api/partners/attractions/:id/images)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "PartnerRouter\n<<Express Router>>" as Router
control "protect + requirePartner + requireApprovedPartner\n<<Middleware Chain>>" as Guard
control "uploadAttractionImages.array + validateUploadedFiles\n<<Upload Middleware>>" as Upload
control "AttractionController\n<<Controller>>" as Attraction
control "AttractionWorkflowService\n<<Service>>" as Workflow
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : POST /api/partners/attractions/:id/images\nmultipart: images[] (max 10)
activate Router
Router -> Guard : protect -> requirePartner -> requireApprovedPartner
activate Guard
ref over Guard, DB : approved-partner guard (see 3.3)
Guard --> Router : next() (req.partner set)
deactivate Guard

Router -> Upload : uploadAttractionImages.array('images',10) + validateUploadedFiles
activate Upload
alt Invalid mimetype / size / signature
  Upload --> Browser : 400 Bad Request
else Files accepted
  Upload --> Router : next() (req.files set)
end
deactivate Upload

Router -> Attraction : uploadImages(req, res, next)
activate Attraction
Attraction -> Prisma : findOwnedAttraction(id, partnerId, include)
activate Prisma
Prisma -> DB : SELECT Attraction
DB --> Prisma : existing | null
Prisma --> Attraction : existing
deactivate Prisma
alt Not found / not owned
  Attraction --> Browser : 404 Not Found
else Found
  Attraction -> Workflow : assertPartnerCanEdit(existing)
  activate Workflow
  Workflow --> Attraction : ok | throw (409/403)
  deactivate Workflow
end
alt No files
  Attraction --> Browser : 400 Bad Request (vui long chon anh)
else Files present
  Attraction -> Attraction : continue processing
end

alt hasPublishedVersion(existing) (write into draftData)
  Attraction -> Attraction : getWorkingDraft(existing); build created images (draft-<uuid>)
  Attraction -> Prisma : saveDraftImages -> attraction.update({ draftData, status:'DRAFT' })
  activate Prisma
  Prisma -> DB : UPDATE Attraction (draft images)
  DB --> Prisma : ok
  Prisma --> Attraction : ok
  deactivate Prisma
  Attraction --> Browser : 201 Created { images }
else No published version (persist rows)
  group Prisma transaction
    Attraction -> Prisma : attractionImage.create x files (first is primary if none)
    activate Prisma
    Prisma -> DB : INSERT AttractionImage[]
    DB --> Prisma : created
    Prisma --> Attraction : created
    deactivate Prisma
  end
  Attraction --> Browser : 201 Created { images }
end
deactivate Attraction
deactivate Router
@enduml

@startuml
