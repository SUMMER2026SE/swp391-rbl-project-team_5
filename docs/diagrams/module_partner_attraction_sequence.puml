@startuml
title Sequence Diagram - 3.1 Submit Partner KYC (POST /api/partners/register)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "PartnerRouter\n<<Express Router>>" as Router
control "protect\n<<Auth Middleware>>" as Protect
control "PartnerController\n<<Controller>>" as Partner
control "PartnerValidators\n<<Utility>>" as Validators
control "UploadMiddleware\n<<Utility>>" as Upload
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : POST /api/partners/register\nbody: businessName, businessLicenseUrl, taxCode, bank info...
activate Router
Router -> Protect : protect(req, res, next)
activate Protect
ref over Protect, DB : protect middleware (see Module 1 - Auth Middleware)
Protect --> Router : next() (req.user set)
deactivate Protect

Router -> Partner : submitKyc(req, res, next)
activate Partner

== Input Validation ==
Partner -> Validators : validateKyc(req.body)
activate Validators
Validators --> Partner : error message | null
deactivate Validators
alt Validation error
  Partner --> Browser : 400 Bad Request
else Valid
  Partner -> Partner : continue processing
end

Partner -> Upload : isDocumentOwnedByUser(businessLicenseUrl, req.user.id)
activate Upload
Upload --> Partner : boolean
deactivate Upload
alt Document not uploaded via system
  Partner --> Browser : 400 Bad Request (tai lieu phap ly khong hop le)
else Owned
  Partner -> Partner : continue processing
end

== Business Logic ==
Partner -> Prisma : partnerProfile.findUnique({ where:{ userId } })
activate Prisma
Prisma -> DB : SELECT PartnerProfile by userId
activate DB
DB --> Prisma : existing | null
deactivate DB
Prisma --> Partner : existing
deactivate Prisma

Partner -> Partner : isResubmission = existing && status in {REJECTED, SUSPENDED}
alt existing AND not resubmission
  Partner --> Browser : 409 Conflict (da nop ho so truoc do)
else New or resubmission
  Partner -> Partner : continue processing
end

alt isResubmission
  Partner -> Prisma : partnerProfile.update({ status:'PENDING', rejectionReason:null, ...data })
  activate Prisma
  Prisma -> DB : UPDATE PartnerProfile (re-submit)
  activate DB
  DB --> Prisma : partner
  deactivate DB
  Prisma --> Partner : partner
  deactivate Prisma
else New submission
  Partner -> Prisma : partnerProfile.create({ userId, ...data, status:'PENDING' })
  activate Prisma
  Prisma -> DB : INSERT PartnerProfile (PENDING)
  activate DB
  DB --> Prisma : partner
  deactivate DB
  Prisma --> Partner : partner
  deactivate Prisma
end

Partner -> Prisma : user.findUnique({ id }, include profile)
activate Prisma
Prisma -> DB : SELECT User (+ profile)
activate DB
DB --> Prisma : refreshedUser
deactivate DB
Prisma --> Partner : refreshedUser
deactivate Prisma

== Response ==
Partner --> Browser : 200 (resubmit) / 201 (new) { partner, user }
deactivate Partner
deactivate Router
@enduml

