@startuml
title Sequence Diagram - 3.9 Update Attraction (PUT /api/partners/attractions/:id)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "PartnerRouter\n<<Express Router>>" as Router
control "protect + requirePartner + requireApprovedPartner\n<<Middleware Chain>>" as Guard
control "AttractionController\n<<Controller>>" as Attraction
control "PartnerValidators\n<<Utility>>" as Validators
control "AttractionWorkflowService\n<<Service>>" as Workflow
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : PUT /api/partners/attractions/:id\nbody: partial attraction fields
activate Router
Router -> Guard : protect -> requirePartner -> requireApprovedPartner
activate Guard
ref over Guard, DB : approved-partner guard (see 3.3)
Guard --> Router : next() (req.partner set)
deactivate Guard

Router -> Attraction : updateAttraction(req, res, next)
activate Attraction
Attraction -> Prisma : findOwnedAttraction(id, partnerId, include)
activate Prisma
Prisma -> DB : SELECT Attraction
DB --> Prisma : existing | null
Prisma --> Attraction : existing
deactivate Prisma
alt Not found / not owned
  Attraction --> Browser : 404 Not Found
else Found
  Attraction -> Workflow : assertPartnerCanEdit(existing)
  activate Workflow
  Workflow --> Attraction : ok | throw
  deactivate Workflow
end
alt status == PENDING
  Attraction --> Browser : 409 Conflict (dang cho duyet)
else status == SUSPENDED
  Attraction --> Browser : 403 Forbidden (dang bi dinh chi)
else Editable (DRAFT / APPROVED / REJECTED)
  Attraction -> Attraction : continue processing
end

Attraction -> Validators : validateAttraction(body, { partial:true })
activate Validators
Validators --> Attraction : error | null
deactivate Validators
alt Validation error
  Attraction --> Browser : 400 Bad Request
else Valid
  Attraction -> Attraction : data = buildAttractionData(body); extract operationalData
end

alt hasPublishedVersion(existing) (edit becomes a new draft over published)
  Attraction -> Workflow : mergeSnapshot(existing.draftData|snapshot, data, category)
  activate Workflow
  Workflow --> Attraction : merged snapshot
  deactivate Workflow
  Attraction -> Prisma : attraction.update({ draftData: merged, status:'DRAFT', rejectionReason:null })
  activate Prisma
  Prisma -> DB : UPDATE Attraction (draftData)
  DB --> Prisma : ok
  Prisma --> Attraction : ok
  deactivate Prisma
else No published version (direct edit)
  group Prisma transaction
    Attraction -> Prisma : attraction.update({ ...data, status:'DRAFT', rejectionReason:null })
    activate Prisma
    Prisma -> DB : UPDATE Attraction
    DB --> Prisma : ok
    Prisma --> Attraction : ok
    deactivate Prisma
    opt category provided
      Attraction -> Prisma : setCategory(tx, id, category)
      activate Prisma
      Prisma -> DB : UPSERT Category + reset AttractionCategory
      DB --> Prisma : ok
      Prisma --> Attraction : ok
      deactivate Prisma
    end
  end
end

Attraction -> Prisma : attraction.findUnique({ id }, include)
activate Prisma
Prisma -> DB : SELECT Attraction (full)
DB --> Prisma : full
Prisma --> Attraction : full
deactivate Prisma
Attraction --> Browser : 200 OK { message, attraction: toAttractionDetail(full) }
deactivate Attraction
deactivate Router
@enduml

