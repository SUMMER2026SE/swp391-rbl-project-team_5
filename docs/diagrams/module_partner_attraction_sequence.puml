@startuml
title Sequence Diagram - 3.3 Update Partner Settings (PUT /api/partners/settings)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "PartnerRouter\n<<Express Router>>" as Router
control "protect + requirePartner + requireApprovedPartner\n<<Middleware Chain>>" as Guard
control "PartnerController\n<<Controller>>" as Partner
control "Validators\n<<Utility>>" as Validators
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : PUT /api/partners/settings\nbody: businessName?, website?, description?, bank...?, displayName?, phone?
activate Router

== Middleware ==
Router -> Guard : protect -> requirePartner -> requireApprovedPartner
activate Guard
ref over Guard, DB : protect (Module 1) + load PartnerProfile by userId
alt No partner profile
  Guard --> Browser : 403 PARTNER_PROFILE_REQUIRED
else partner.status != APPROVED
  Guard --> Browser : 403 PARTNER_APPROVAL_REQUIRED
else Approved
  Guard --> Router : next() (req.partner set)
end
deactivate Guard

Router -> Partner : updateSettings(req, res, next)
activate Partner

alt businessName provided but empty
  Partner --> Browser : 400 Bad Request (ten hien thi khong duoc trong)
else Valid / not provided
  Partner -> Partner : build partnerUpdate (website, description, bank fields)
end
opt phone provided
  Partner -> Validators : isValidPhoneNumber(phone)
  activate Validators
  Validators --> Partner : boolean
  deactivate Validators
  alt Invalid phone
    Partner --> Browser : 400 Bad Request
  else Valid
    Partner -> Partner : profileUpdate.phoneNumber = phone
  end
end

Partner -> Prisma : partnerProfile.update({ where:{ id: req.partner.id }, data: partnerUpdate })
activate Prisma
Prisma -> DB : UPDATE PartnerProfile
activate DB
DB --> Prisma : partner
deactivate DB
Prisma --> Partner : partner
deactivate Prisma

Partner -> Prisma : user.findUnique({ id }, include profile)
activate Prisma
Prisma -> DB : SELECT User (+ profile)
DB --> Prisma : user
Prisma --> Partner : user
deactivate Prisma

opt userUpdate or profileUpdate not empty
  Partner -> Prisma : user.update({ ...userUpdate, profile:{ upsert } }, include profile)
  activate Prisma
  Prisma -> DB : UPDATE User + upsert UserProfile
  DB --> Prisma : user
  Prisma --> Partner : user
  deactivate Prisma
end

Partner --> Browser : 200 OK { message, partner }
deactivate Partner
deactivate Router
@enduml

