@startuml
title Sequence Diagram - 3.15 Submit Attraction for Admin Review (PUT /api/attractions/:id/submit)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "AttractionRouter\n<<Express Router>>" as Router
control "protect + restrictTo('PARTNER') + requirePartner + requireApprovedPartner\n<<Middleware Chain>>" as Guard
control "AttractionController\n<<Controller>>" as Attraction
control "AttractionWorkflowService\n<<Service>>" as Workflow
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : PUT /api/attractions/:id/submit
activate Router
Router -> Guard : protect -> restrictTo('PARTNER') -> requirePartner -> requireApprovedPartner
activate Guard
ref over Guard, DB : role + approved-partner guard
Guard --> Router : next() (req.user, req.partner set)
deactivate Guard

Router -> Attraction : submitAttraction(req, res, next)
activate Attraction
alt Missing userId
  Attraction --> Browser : 401 UNAUTHENTICATED
else Authenticated
  Attraction -> Prisma : partnerProfile.findUnique({ where:{ userId } })
  activate Prisma
  Prisma -> DB : SELECT PartnerProfile
  DB --> Prisma : partner | null
  Prisma --> Attraction : partner
  deactivate Prisma
end
alt No partner profile
  Attraction --> Browser : 403 NO_PARTNER_PROFILE
else Partner found
  Attraction -> Prisma : attraction.findUnique({ id }, include)
  activate Prisma
  Prisma -> DB : SELECT Attraction (+ tickets + slots + special dates)
  DB --> Prisma : attraction | null
  Prisma --> Attraction : attraction
  deactivate Prisma
end
alt Not found / archived
  Attraction --> Browser : 404 Not Found
else attraction.partnerId != partner.id
  Attraction --> Browser : 403 FORBIDDEN
else Owned
  Attraction -> Attraction : continue processing
end
alt status not in {DRAFT, REJECTED}
  Attraction --> Browser : 400 INVALID_STATUS
else Submittable
  Attraction -> Workflow : snapshot = draftData || buildAttractionSnapshot(attraction)
  activate Workflow
  Workflow --> Attraction : snapshot
  deactivate Workflow
  Attraction -> Workflow : validateSubmissionSnapshot(snapshot)
  activate Workflow
  Workflow --> Attraction : missing[]
  deactivate Workflow
end
alt missing.length > 0
  Attraction --> Browser : 400 INCOMPLETE_ATTRACTION (thieu: ...)
else Complete
  group Prisma transaction
    Attraction -> Prisma : attraction.updateMany({ DRAFT/REJECTED -> PENDING, revision++, submittedAt, submittedData })
    activate Prisma
    Prisma -> DB : UPDATE Attraction (PENDING)
    DB --> Prisma : count
    Prisma --> Attraction : ok
    deactivate Prisma
    Attraction -> Prisma : attraction.findUnique({ id })
    activate Prisma
    Prisma -> DB : SELECT Attraction (updated)
    DB --> Prisma : updated
    Prisma --> Attraction : updated
    deactivate Prisma
    Attraction -> Prisma : auditLog.create({ action:'ATTRACTION_SUBMITTED', entityId, metadata })
    activate Prisma
    Prisma -> DB : INSERT AuditLog
    DB --> Prisma : ok
    Prisma --> Attraction : ok
    deactivate Prisma
  end
  Attraction --> Browser : 200 OK { data:{ id, status:'PENDING' } }
end
deactivate Attraction
deactivate Router
@enduml

@startuml
title Sequence Diagram - 3.16 Set Attraction Publication Status (PATCH /api/partners/attractions/:id/publication)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "PartnerRouter\n<<Express Router>>" as Router
control "protect + requirePartner + requireApprovedPartner\n<<Middleware Chain>>" as Guard
control "AttractionController\n<<Controller>>" as Attraction
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : PATCH /api/partners/attractions/:id/publication\nbody: publicationStatus (ACTIVE | PAUSED)
activate Router
Router -> Guard : protect -> requirePartner -> requireApprovedPartner
activate Guard
ref over Guard, DB : approved-partner guard (see 3.3)
Guard --> Router : next() (req.partner set)
deactivate Guard

Router -> Attraction : setPublicationStatus(req, res, next)
activate Attraction
Attraction -> Prisma : findOwnedAttraction(id, partnerId)
activate Prisma
Prisma -> DB : SELECT Attraction
DB --> Prisma : attraction | null
Prisma --> Attraction : attraction
deactivate Prisma

alt Not found / not owned
  Attraction --> Browser : 404 NOT_FOUND
else Found
  Attraction -> Attraction : continue processing
end
alt !attraction.publishedAt (never approved)
  Attraction --> Browser : 400 INVALID_STATE (chua tung duoc phe duyet)
else Published before
  Attraction -> Attraction : continue processing
end
alt attraction.status == SUSPENDED
  Attraction --> Browser : 403 FORBIDDEN (dang bi dinh chi)
else Not suspended
  Attraction -> Attraction : continue processing
end
alt publicationStatus not in {ACTIVE, PAUSED}
  Attraction --> Browser : 400 VALIDATION_ERROR
else Valid value
  Attraction -> Prisma : attraction.update({ publicationStatus })
  activate Prisma
  Prisma -> DB : UPDATE Attraction publicationStatus
  DB --> Prisma : ok
  Prisma --> Attraction : ok
  deactivate Prisma
  Attraction --> Browser : 200 OK { message }
end
deactivate Attraction
deactivate Router
@enduml
