Attraction -> Prisma : findOwnedAttraction(id, partnerId, ordered images)
activate Prisma
Prisma -> DB : SELECT Attraction (+ images)
DB --> Prisma : attraction | null
Prisma --> Attraction : attraction
deactivate Prisma
alt Not found / not owned
  Attraction --> Browser : 404 Not Found
else Found
  Attraction -> Workflow : assertPartnerCanEdit(attraction)
  activate Workflow
  Workflow --> Attraction : ok | throw
  deactivate Workflow
end

alt hasPublishedVersion(attraction) (edit draftData)
  Attraction -> Attraction : find image in draft.images
  alt Image not in draft
    Attraction --> Browser : 404 Not Found (khong tim thay anh)
  else Found
    Attraction -> Attraction : remove image; reassign primary if needed
    Attraction -> Prisma : saveDraftImages -> attraction.update({ draftData })
    activate Prisma
    Prisma -> DB : UPDATE Attraction (draft images)
    DB --> Prisma : ok
    Prisma --> Attraction : ok
    deactivate Prisma
    Attraction --> Browser : 200 OK { message }
  end
else No published version (delete row)
  Attraction -> Attraction : find image in attraction.images
  alt Image not found
    Attraction --> Browser : 404 Not Found
  else Found
    group Prisma transaction
      Attraction -> Prisma : attractionImage.delete({ id })
      activate Prisma
      Prisma -> DB : DELETE AttractionImage
      DB --> Prisma : ok
      Prisma --> Attraction : ok
      deactivate Prisma
      opt deleted image was primary
        Attraction -> Prisma : attractionImage.update({ replacement, isPrimary:true })
        activate Prisma
        Prisma -> DB : UPDATE AttractionImage (new primary)
        DB --> Prisma : ok
        Prisma --> Attraction : ok
        deactivate Prisma
      end
    end
    Attraction --> Browser : 200 OK { message }
  end
end
deactivate Attraction
deactivate Router
@enduml

