@startuml
title Sequence Diagram - 8.7 Review Attraction Submission (PUT /api/admin/attractions/:id/review)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "AdminRouter\n<<Express Router>>" as Router
control "protect + restrictTo('ADMIN')\n<<Middleware Chain>>" as Guard
control "AdminController\n<<Controller>>" as Admin
control "AttractionWorkflowService\n<<Service>>" as Workflow
control "Mailer\n<<Email Service>>" as Mailer
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : PUT /api/admin/attractions/:id/review\nbody: action (APPROVED|REJECTED), rejectionReason?
activate Router
Router -> Guard : protect -> restrictTo('ADMIN')
activate Guard
ref over Guard, DB : ADMIN guard (see 8.1)
Guard --> Router : next()
deactivate Guard

Router -> Admin : reviewAttraction(req, res, next)
activate Admin
alt action invalid
  Admin --> Browser : 400 VALIDATION_ERROR
else REJECTED without reason
  Admin --> Browser : 400 VALIDATION_ERROR
else Valid
  Admin -> Prisma : attraction.findUnique({ id }, include partner.user)
  activate Prisma
  Prisma -> DB : SELECT Attraction (+ partner + user)
  DB --> Prisma : attraction | null
  Prisma --> Admin : attraction
  deactivate Prisma
end
alt Not found / archived
  Admin --> Browser : 404 Not Found
else status != PENDING or no submittedData
  Admin --> Browser : 409 INVALID_STATE
else Reviewable
  Admin -> Workflow : validateSubmissionSnapshot(submittedData)
  activate Workflow
  Workflow --> Admin : missing[]
  deactivate Workflow
end
alt action APPROVED and missing.length > 0
  Admin --> Browser : 409 INCOMPLETE_SUBMISSION
else action APPROVED and category inactive
  Admin --> Browser : 409 CATEGORY_UNAVAILABLE
else Proceed
  group Prisma transaction
    Admin -> Prisma : attraction.updateMany({ id, status:PENDING, revision } -> reviewedAt) (optimistic lock)
    activate Prisma
    Prisma -> DB : UPDATE lock (guard revision)
    DB --> Prisma : count
    Prisma --> Admin : lock
    deactivate Prisma
    alt lock.count != 1 (handled by another admin)
      Admin --> Browser : 409 Conflict
    else Locked
      alt action == APPROVED
        Admin -> Workflow : applyApprovedSnapshot(tx, id, snapshot)
        activate Workflow
        Workflow -> Prisma : sync attraction fields + images + tickets + schedule
        activate Prisma
        Prisma -> DB : UPDATE/INSERT Attraction/Image/Ticket/TimeSlot/SpecialDate
        Prisma --> Workflow : ok
        deactivate Prisma
        Workflow --> Admin : ok
        deactivate Workflow
        Admin -> Prisma : refreshAttractionMinPrice + attraction.update(APPROVED, published, clear draft/submitted)
        activate Prisma
        Prisma -> DB : UPDATE Attraction (APPROVED + publishedAt)
        Prisma --> Admin : ok
        deactivate Prisma
      else action == REJECTED
        Admin -> Prisma : attraction.update(REJECTED, rejectionReason, draftData=snapshot, clear submitted)
        activate Prisma
        Prisma -> DB : UPDATE Attraction (REJECTED)
        Prisma --> Admin : ok
        deactivate Prisma
      end
      Admin -> Prisma : auditLog.create({ ATTRACTION_APPROVED | ATTRACTION_REJECTED })
      activate Prisma
      Prisma -> DB : INSERT AuditLog
      Prisma --> Admin : ok
      deactivate Prisma
    end
  end
  Admin -> Mailer : sendAttractionReviewEmail(action, reason) (non-blocking)
  activate Mailer
  Mailer --> Admin : result
  deactivate Mailer
  Admin --> Browser : 200 OK { message }
end
deactivate Admin
deactivate Router
@enduml

