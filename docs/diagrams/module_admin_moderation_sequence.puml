@startuml
title Sequence Diagram - 8.3 Change User Status (PATCH /api/admin/users/:id/status)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "AdminRouter\n<<Express Router>>" as Router
control "protect + restrictTo('ADMIN')\n<<Middleware Chain>>" as Guard
control "AdminController\n<<Controller>>" as Admin
control "Mailer\n<<Email Service>>" as Mailer
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : PATCH /api/admin/users/:id/status\nbody: status (ACTIVE|LOCKED), reason?, sendEmail?
activate Router
Router -> Guard : protect -> restrictTo('ADMIN')
activate Guard
ref over Guard, DB : ADMIN guard (see 8.1)
Guard --> Router : next()
deactivate Guard

Router -> Admin : changeUserStatus(req, res, next)
activate Admin
alt status not in {ACTIVE, LOCKED}
  Admin --> Browser : 400 Bad Request
else Valid status
  Admin -> Prisma : user.findUnique({ id }, include profile+roles)
  activate Prisma
  Prisma -> DB : SELECT User
  DB --> Prisma : user | null
  Prisma --> Admin : user
  deactivate Prisma
end
alt User not found
  Admin --> Browser : 404 Not Found
else LOCKED and target == self
  Admin --> Browser : 400 Bad Request (khong the tu khoa)
else Allowed
  group Prisma transaction
    Admin -> Prisma : user.update({ status, tokenVersion++ })
    activate Prisma
    Prisma -> DB : UPDATE User status
    Prisma --> Admin : nextUser
    deactivate Prisma
    opt status == LOCKED
      Admin -> Prisma : authSession.updateMany({ revokedAt })
      activate Prisma
      Prisma -> DB : UPDATE revoke sessions
      Prisma --> Admin : ok
      deactivate Prisma
    end
  end
  opt sendEmail == true
    Admin -> Mailer : sendAccountStatusEmail({ to, status, reason }) (non-blocking)
    activate Mailer
    Mailer --> Admin : result
    deactivate Mailer
  end
  Admin --> Browser : 200 OK { user: sanitizeUser(updatedUser) }
end
deactivate Admin
deactivate Router
@enduml

