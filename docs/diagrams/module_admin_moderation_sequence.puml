control "Mailer\n<<Email Service>>" as Mailer
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : PUT /api/admin/attractions/:id/hide\nbody: reason
activate Router
Router -> Guard : protect -> restrictTo('ADMIN')
activate Guard
ref over Guard, DB : ADMIN guard (see 8.1)
Guard --> Router : next()
deactivate Guard

Router -> Admin : hideAttraction(req, res, next)
activate Admin
alt Missing reason
  Admin --> Browser : 400 VALIDATION_ERROR
else Reason present
  Admin -> Prisma : attraction.findUnique({ id }, include partner.user)
  activate Prisma
  Prisma -> DB : SELECT Attraction (+ partner + user)
  DB --> Prisma : attraction | null
  Prisma --> Admin : attraction
  deactivate Prisma
end
alt Not found / archived
  Admin --> Browser : 404 Not Found
else status != APPROVED or not published
  Admin --> Browser : 409 INVALID_STATUS_TRANSITION
else Suspendable
  group Prisma transaction
    Admin -> Prisma : attraction.updateMany({ id, status:APPROVED } -> SUSPENDED, PAUSED, reason)
    activate Prisma
    Prisma -> DB : UPDATE Attraction SUSPENDED (guard)
    DB --> Prisma : count
    Prisma --> Admin : updated
    deactivate Prisma
    alt updated.count != 1 (raced)
      Admin --> Browser : 409 Conflict
    else Suspended
      Admin -> Prisma : auditLog.create({ ATTRACTION_SUSPENDED })
      activate Prisma
      Prisma -> DB : INSERT AuditLog
      Prisma --> Admin : ok
      deactivate Prisma
    end
  end
  Admin -> Mailer : sendAttractionViolationEmail(reason) (non-blocking)
  activate Mailer
  Mailer --> Admin : result
  deactivate Mailer
  Admin --> Browser : 200 OK { message }
end
deactivate Admin
deactivate Router
@enduml

