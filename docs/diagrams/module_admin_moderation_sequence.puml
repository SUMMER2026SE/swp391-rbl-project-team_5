@startuml
title Sequence Diagram - 8.5 Review Partner KYC (PUT /api/admin/partners/:id/review)

autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "AdminRouter\n<<Express Router>>" as Router
control "protect + restrictTo('ADMIN')\n<<Middleware Chain>>" as Guard
control "AdminController\n<<Controller>>" as Admin
control "Mailer\n<<Email Service>>" as Mailer
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : PUT /api/admin/partners/:id/review\nbody: action (APPROVED|REJECTED), rejectionReason?
activate Router
Router -> Guard : protect -> restrictTo('ADMIN')
activate Guard
ref over Guard, DB : ADMIN guard (see 8.1)
Guard --> Router : next()
deactivate Guard

Router -> Admin : reviewPartner(req, res, next)
activate Admin
alt action not in {APPROVED, REJECTED}
  Admin --> Browser : 400 VALIDATION_ERROR
else REJECTED without rejectionReason
  Admin --> Browser : 400 VALIDATION_ERROR
else Valid
  Admin -> Prisma : partnerProfile.findUnique({ id }, include user)
  activate Prisma
  Prisma -> DB : SELECT PartnerProfile (+ user)
  DB --> Prisma : partner | null
  Prisma --> Admin : partner
  deactivate Prisma
end
alt Partner not found
  Admin --> Browser : 404 Not Found
else status != PENDING
  Admin --> Browser : 409 INVALID_STATUS
else Pending
  alt action == APPROVED
    group Prisma transaction
      Admin -> Prisma : partnerProfile.update(APPROVED) + user.update(role PARTNER) + grantRole(CUSTOMER, PARTNER)
      activate Prisma
      Prisma -> DB : UPDATE PartnerProfile + User + RoleMembership
      Prisma --> Admin : ok
      deactivate Prisma
    end
    Admin -> Mailer : sendPartnerReviewEmail(APPROVED) (non-blocking)
    activate Mailer
    Mailer --> Admin : result
    deactivate Mailer
  else action == REJECTED
    group Prisma transaction
      Admin -> Prisma : partnerProfile.update(REJECTED, reason) + user.update(role CUSTOMER) + grant(CUSTOMER)/revoke(PARTNER)
      activate Prisma
      Prisma -> DB : UPDATE PartnerProfile + User + RoleMembership
      Prisma --> Admin : ok
      deactivate Prisma
    end
    Admin -> Mailer : sendPartnerReviewEmail(REJECTED, reason) (non-blocking)
    activate Mailer
    Mailer --> Admin : result
    deactivate Mailer
  end
  Admin --> Browser : 200 OK { message }
end
deactivate Admin
deactivate Router
@enduml

