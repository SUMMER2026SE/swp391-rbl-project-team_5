skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 25
skinparam BoxPadding 10

boundary "Browser / Frontend" as Browser
control "AdminRouter\n<<Express Router>>" as Router
control "protect + restrictTo('ADMIN')\n<<Middleware Chain>>" as Guard
control "AdminController\n<<Controller>>" as Admin
control "AnalyticsService\n<<Service>>" as Analytics
database "PrismaClient\n<<ORM>>" as Prisma
database "PostgreSQL\nDatabase" as DB

Browser -> Router : GET /api/admin/dashboard?period=...
activate Router
Router -> Guard : protect -> restrictTo('ADMIN')
activate Guard
ref over Guard, DB : protect (Module 1) + ADMIN role check
Guard --> Router : next() (req.user set)
deactivate Guard

Router -> Admin : getDashboard(req, res, next)
activate Admin
Admin -> Analytics : normalizePeriod / getPeriodStart(period)
activate Analytics
Analytics --> Admin : period, startDate
deactivate Analytics

group Promise.all
  Admin -> Prisma : user.count / attraction.count / attraction.count(active) / partnerProfile.count(PENDING) / partnerProfile.count(new) / booking.count(period)
  activate Prisma
  Prisma -> DB : COUNT users / attractions / partners / bookings
  DB --> Prisma : counts
  Prisma --> Admin : counts
  deactivate Prisma
  Admin -> Admin : getPlatformFinancialReport(period)
  activate Admin
  Admin -> Prisma : payment.aggregate + timeline queries
  activate Prisma
  Prisma -> DB : SUM/GROUP payments
  DB --> Prisma : financialReport
  Prisma --> Admin : financialReport
  deactivate Prisma
  Admin --> Admin : financialReport
  deactivate Admin
  Admin -> Prisma : partnerProfile.findMany(PENDING take 5) / attraction.findMany(PENDING take 6)
  activate Prisma
  Prisma -> DB : SELECT pending partners + attractions
  DB --> Prisma : pending lists
  Prisma --> Admin : pending lists
  deactivate Prisma
end

Admin --> Browser : 200 OK { stats, trend, pendingPartners, pendingAttractions }
deactivate Admin
deactivate Router
@enduml

