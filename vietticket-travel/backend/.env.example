# ============================================
# VietTicket Travel — Backend Environment
# Sao chép file này thành .env rồi điền giá trị thật
# ============================================

# --- Cơ sở dữ liệu PostgreSQL ---
# Định dạng: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vietticket?schema=public"

# --- Máy chủ ---
PORT=5000
NODE_ENV=development
TRUST_PROXY=false

# URL frontend (cho CORS) và backend (cho link ảnh upload)
FRONTEND_URL="http://localhost:5173"
BACKEND_URL="http://localhost:5000"

# --- JWT ---
# Chuỗi bí mật ngẫu nhiên, đổi thành giá trị riêng của bạn khi triển khai
JWT_SECRET="doi-thanh-mot-chuoi-bi-mat-that-dai-va-ngau-nhien"
JWT_EXPIRES_IN="1d"

# --- Tạo tài khoản quản trị bằng npm run create-admin ---
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# --- Google OAuth (tùy chọn) ---
GOOGLE_CLIENT_ID=""

# --- AI Assistant (tùy chọn; điền ít nhất một provider để chatbot gọi AI thật) ---
AI_PRIMARY_PROVIDER="gemini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# --- VNPay (Sandbox) ---
# Lấy TmnCode & HashSecret từ tài khoản VNPay Sandbox (https://sandbox.vnpayment.vn)
VNP_TMNCODE=""
VNP_HASHSECRET=""
VNP_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
# Return: VNPay redirect trình duyệt về backend để verify rồi chuyển tiếp sang FE
VNP_RETURNURL="http://localhost:5000/api/payments/vnpay-return"
# IPN: VNPay gọi server-to-server để cập nhật DB (khai báo URL này trên cổng VNPay).
# Production phải dùng URL HTTPS công khai; VNPay không thể gọi localhost của máy dev.
# Ở local, vnpay-return có chữ ký hợp lệ sẽ đối soát dự phòng sau khi trình duyệt quay về.
VNP_IPNURL="http://localhost:5000/api/payments/vnpay-ipn"
# API hoàn tiền (refund) — endpoint merchant API của VNPay Sandbox
VNP_API="https://sandbox.vnpayment.vn/merchant_webapi/api/transaction"

# --- Gửi email (tùy chọn — bỏ trống sẽ log ra console ở chế độ dev) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="VietTicket Travel <no-reply@vietticket.com>"

# --- AI Assistant (Chatbot / Gợi ý / Kế hoạch tham quan) ---
# Cấu hình ít nhất 1 trong 2 key dưới đây. Có thể cấu hình cả 2 để
# hệ thống tự fallback sang provider phụ khi provider chính lỗi/hết quota.
GEMINI_API_KEY=""
OPENAI_API_KEY=""
# Provider được thử trước: "gemini" hoặc "openai" (mặc định: gemini)
AI_PRIMARY_PROVIDER="gemini"
# Tuỳ chọn: đổi model cụ thể (có giá trị mặc định nếu để trống)
GEMINI_MODEL="gemini-2.0-flash"
OPENAI_MODEL="gpt-4o-mini"

# --- AI Revenue Forecasting (ml-service FastAPI, ensemble RF + XGBoost) ---
ML_SERVICE_URL="http://localhost:8000"
# Phải khớp với ML_SERVICE_API_KEY trong ml-service/.env (để trống nếu ml-service không bật auth)
ML_SERVICE_API_KEY=""
ML_SERVICE_TIMEOUT_MS=8000
# Thời gian (ms) một dự báo đã lưu được coi là còn "mới", tránh gọi lại ml-service liên tục
FORECAST_CACHE_TTL_MS=21600000


