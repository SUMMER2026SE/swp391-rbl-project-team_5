generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  PARTNER
  ADMIN
  STAFF
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum UserStatus {
  ACTIVE
  LOCKED
}

model User {
  id                String       @id @default(uuid())
  email             String       @unique
  passwordHash      String?
  fullName          String
  role              UserRole     @default(CUSTOMER)
  provider          AuthProvider @default(LOCAL)
  isEmailVerified   Boolean      @default(false)
  status            UserStatus   @default(ACTIVE)
  tokenVersion      Int          @default(0)
  termsAcceptedAt   DateTime?
  termsVersion      String?
  privacyVersion    String?
  consentIpAddress  String?
  // Đối tác chủ quản của nhân viên này. Chỉ set khi role = STAFF.
  employerPartnerId String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  profile                 UserProfile?
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  oauthAccounts           OAuthAccount[]
  authSessions            AuthSession[]
  roleMemberships         UserRoleMembership[]
  partnerProfile          PartnerProfile?
  employer                PartnerProfile?             @relation("PartnerStaff", fields: [employerPartnerId], references: [id], onDelete: Cascade)
  favoriteAttractions     FavoriteAttraction[]
  reviews                 Review[]
  reservations            Reservation[]
  bookings                Booking[]
  supportTickets          SupportTicket[]
  assignedSupportTickets  SupportTicket[]             @relation("SupportAssignedStaff")
  staffAssignments        StaffAttractionAssignment[] @relation("StaffAssignments")
  createdStaffAssignments StaffAttractionAssignment[] @relation("StaffAssignmentsCreatedBy")
  checkedInTickets        TicketInstance[]            @relation("TicketCheckedInBy")
  auditLogs               AuditLog[]
  savedItineraries        SavedItinerary[]
  liveTrips               LiveTrip[]
  smartQueueEntries       SmartQueueEntry[]
  liveTripEvents          LiveTripEvent[]
  smartQueuePolicies      SmartQueuePolicy[]          @relation("SmartQueuePolicyUpdatedBy")
  calledQueueEntries      SmartQueueEntry[]           @relation("SmartQueueCalledBy")
  pausedQueuePolicies     SmartQueuePolicy[]          @relation("SmartQueuePolicyPausedBy")

  @@index([employerPartnerId])
}

model UserRoleMembership {
  userId    String
  role      UserRole
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
  @@index([role])
}

model UserProfile {
  id          String    @id @default(uuid())
  userId      String    @unique
  phoneNumber String?
  avatarUrl   String?
  dateOfBirth DateTime?
  gender      String?
  address     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OAuthAccount {
  id                String   @id @default(uuid())
  userId            String
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model AuthSession {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String?   @unique
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

// ==========================================
// CÁC ENUM MỚI DÀNH CHO MODULE 2
// ==========================================

enum PartnerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum AttractionStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum AttractionPublicationStatus {
  PAUSED
  ACTIVE
  ARCHIVED
}

enum AttractionOperationalStatus {
  ACTIVE
  SUSPENDED
}

enum AttractionEnvironment {
  INDOOR
  OUTDOOR
  MIXED
}

enum TicketStatus {
  ACTIVE
  INACTIVE
}

enum TicketType {
  ADULT
  CHILD
  STUDENT
  FAMILY
  GROUP
}

enum RefundPolicyType {
  NON_REFUNDABLE
  FREE_CANCELLATION
  REFUND_WITH_FEE
}

// Reservation enum + model (Task 6)
enum ReservationStatus {
  HELD
  CONFIRMED
  EXPIRED
  CANCELLED
}

enum BookingStatus {
  PENDING_PAYMENT
  PENDING_PARTNER
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  REFUND_REQUESTED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum SettlementStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED
}

enum TicketInstanceStatus {
  VALID
  USED
  EXPIRED
  REFUNDED
}

enum VoucherDiscountType {
  FIXED
  PERCENTAGE
}

model Reservation {
  id                        String            @id @default(uuid())
  userId                    String
  ticketProductId           String
  timeSlotId                String?
  date                      DateTime          @db.Date
  quantity                  Int
  status                    ReservationStatus @default(HELD)
  expiresAt                 DateTime
  paymentDeadline           DateTime?
  paymentAttemptCount       Int               @default(0)
  snapshotUnitPrice         Decimal?          @db.Decimal(12, 2)
  snapshotRefundPolicy      RefundPolicyType?
  snapshotRefundFeeRate     Decimal?          @db.Decimal(5, 2)
  snapshotRefundCutoffHours Int?
  snapshotCommissionRate    Decimal?          @db.Decimal(5, 2)
  createdAt                 DateTime          @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketProduct TicketProduct @relation(fields: [ticketProductId], references: [id], onDelete: Cascade)
  timeSlot      TimeSlot?     @relation(fields: [timeSlotId], references: [id])
  booking       Booking?

  @@index([status, expiresAt])
  @@index([userId, createdAt])
  @@index([ticketProductId, date])
}

// ==========================================
// CÁC MODEL THIẾT KẾ MỚI
// ==========================================

model PartnerProfile {
  id                   String        @id @default(uuid())
  userId               String        @unique
  businessName         String
  businessLicenseUrl   String?
  taxCode              String        @unique
  registrationDate     DateTime?     @db.Date
  representativeName   String?
  representativePhone  String?
  businessAddress      String?
  bankName             String?
  branchName           String?
  bankAccountNumber    String?
  bankAccountName      String?
  swiftCode            String?
  payoutCurrency       String        @default("VND")
  website              String?
  description          String?
  kycConsentAccepted   Boolean       @default(false)
  kycConsentVersion    String?
  kycConsentAcceptedAt DateTime?
  kycConsentIpAddress  String?
  commissionRate       Decimal       @default(0.10) @db.Decimal(5, 2)
  status               PartnerStatus @default(PENDING)
  rejectionReason      String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  attractions  Attraction[]
  staffMembers User[]              @relation("PartnerStaff")
  settlements  PartnerSettlement[]
}

model StaffAttractionAssignment {
  id           String    @id @default(uuid())
  staffId      String
  attractionId String
  createdById  String?
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?

  staff      User       @relation("StaffAssignments", fields: [staffId], references: [id], onDelete: Cascade)
  attraction Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  createdBy  User?      @relation("StaffAssignmentsCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([staffId, attractionId])
  @@index([staffId, revokedAt])
  @@index([attractionId, revokedAt])
}

model Attraction {
  id                      String                      @id @default(uuid())
  partnerId               String
  title                   String
  description             String                      @db.Text
  address                 String
  city                    String
  district                String?
  searchTextNormalized    String                      @default("") @db.Text
  locationTextNormalized  String                      @default("") @db.Text
  openTime                String? // Giờ mở cửa, định dạng "HH:MM"
  closeTime               String? // Giờ đóng cửa, định dạng "HH:MM"
  openDays                String? // 7 ngày trong tuần dạng CSV bool, vd "1,1,1,1,1,0,0"
  defaultCapacity         Int                         @default(100)
  requiresManualApproval  Boolean                     @default(false) // Đơn đặt vé cần đối tác duyệt thủ công
  recommendedVisitMinutes Int                         @default(150)
  environment             AttractionEnvironment       @default(MIXED)
  isFullDay               Boolean                     @default(false)
  latitude                Float?
  longitude               Float?
  status                  AttractionStatus            @default(DRAFT)
  publicationStatus       AttractionPublicationStatus @default(PAUSED)
  operationalStatus       AttractionOperationalStatus @default(ACTIVE)
  suspensionReason        String?
  suspendedAt             DateTime?
  suspendedById           String?
  rejectionReason         String?
  draftData               Json?
  submittedData           Json?
  revision                Int                         @default(0)
  submittedAt             DateTime?
  reviewedAt              DateTime?
  reviewedById            String?
  publishedAt             DateTime?
  averageRating           Float                       @default(0.0)
  totalReviews            Int                         @default(0)
  minTicketPrice          Decimal?                    @db.Decimal(12, 2)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  archivedAt              DateTime?

  partner        PartnerProfile       @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  images         AttractionImage[]
  categories     AttractionCategory[]
  ticketProducts TicketProduct[]
  favoritedBy    FavoriteAttraction[]
  reviews        Review[]
  timeSlots      TimeSlot[] // Khung giờ cấp điểm tham quan (Module 2)
  specialDates   SpecialDate[] // Lịch đặc biệt (đóng cửa / đổi sức chứa)

  dailyStocks         AttractionDailyStock[]
  staffAssignments    StaffAttractionAssignment[]
  revenueForecasts    RevenueForecast[]
  liveTripItems       LiveTripItem[]
  smartQueueEntries   SmartQueueEntry[]
  smartQueuePolicy    SmartQueuePolicy?
  arrivalObservations ArrivalObservation[]
  livePredictions     LivePrediction[]

  @@index([city])
  @@index([status])
  @@index([publicationStatus])
  @@index([operationalStatus])
  @@index([archivedAt])
  @@index([minTicketPrice])
  @@index([searchTextNormalized(ops: raw("gin_trgm_ops"))], type: Gin, map: "Attraction_searchTextNormalized_trgm_idx")
  @@index([locationTextNormalized(ops: raw("gin_trgm_ops"))], type: Gin, map: "Attraction_locationTextNormalized_trgm_idx")
}

model AttractionImage {
  id           String   @id @default(uuid())
  attractionId String
  imageUrl     String
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  attraction Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)

  @@index([attractionId])
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attractions AttractionCategory[]
}

model NewsletterSubscription {
  id           String   @id @default(uuid())
  email        String   @unique
  isActive     Boolean  @default(true)
  subscribedAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
}

model AttractionCategory {
  attractionId String
  categoryId   String

  attraction Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([attractionId, categoryId])
}

model TicketProduct {
  id                String           @id @default(uuid())
  attractionId      String
  name              String
  type              TicketType       @default(ADULT)
  description       String           @db.Text
  originalPrice     Decimal          @db.Decimal(12, 2)
  sellingPrice      Decimal          @db.Decimal(12, 2)
  status            TicketStatus     @default(ACTIVE)
  refundPolicy      RefundPolicyType @default(NON_REFUNDABLE)
  refundFeeRate     Decimal          @default(0.0) @db.Decimal(5, 2)
  refundCutoffHours Int              @default(24)
  minAgeYears       Int?
  maxAgeYears       Int?
  minHeightCm       Int?
  maxHeightCm       Int?
  requiresAdult     Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  archivedAt        DateTime?

  attraction      Attraction       @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  timeSlots       TimeSlot[]
  dailyStocks     DailyStock[]
  reservations    Reservation[]
  ticketInstances TicketInstance[]

  @@index([archivedAt])
}

model TimeSlot {
  id              String  @id @default(uuid())
  ticketProductId String? // Khung giờ theo gói vé (luồng đặt vé)
  attractionId    String? // Khung giờ cấp điểm tham quan (Module 2 - trang Lịch)
  startTime       String
  endTime         String
  maxCapacity     Int
  isActive        Boolean @default(true)

  ticketProduct  TicketProduct?  @relation(fields: [ticketProductId], references: [id], onDelete: Cascade)
  attraction     Attraction?     @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  timeSlotStocks TimeSlotStock[]
  reservations   Reservation[]

  @@index([attractionId])
}

model SpecialDate {
  id           String   @id @default(uuid())
  attractionId String
  date         DateTime @db.Date
  closed       Boolean  @default(false)
  capacity     Int? // Sức chứa ghi đè cho ngày này (null = dùng mặc định)
  note         String?
  createdAt    DateTime @default(now())

  attraction Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)

  @@unique([attractionId, date])
}

model DailyStock {
  id              String   @id @default(uuid())
  ticketProductId String
  date            DateTime
  capacity        Int
  bookedQuantity  Int      @default(0)
  heldQuantity    Int      @default(0)

  ticketProduct TicketProduct @relation(fields: [ticketProductId], references: [id], onDelete: Cascade)

  @@unique([ticketProductId, date])
  @@index([date])
}

model AttractionDailyStock {
  id           String   @id @default(uuid())
  attractionId String
  date         DateTime @db.Date
  capacity     Int
  bookedQty    Int      @default(0)
  heldQty      Int      @default(0)

  attraction Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)

  @@unique([attractionId, date])
  @@index([date])
}

model TimeSlotStock {
  id         String   @id @default(uuid())
  timeSlotId String
  date       DateTime
  bookedQty  Int      @default(0)
  heldQty    Int      @default(0)

  timeSlot TimeSlot @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)

  @@unique([timeSlotId, date])
  @@index([date])
}

model FavoriteAttraction {
  userId       String
  attractionId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  attraction Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)

  @@id([userId, attractionId])
}

model Review {
  id               String    @id @default(uuid())
  userId           String
  attractionId     String
  bookingId        String?   @unique
  rating           Int
  comment          String?   @db.Text
  isHidden         Boolean   @default(false)
  moderationReason String?   @db.Text
  moderatedAt      DateTime?
  moderatedById    String?
  replyComment     String?   @db.Text
  repliedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  attraction Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  booking    Booking?   @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([attractionId, isHidden, createdAt])
}

model Booking {
  id                         String           @id @default(uuid())
  userId                     String
  reservationId              String           @unique
  voucherId                  String?
  subtotalAmount             Decimal          @db.Decimal(12, 2)
  discountAmount             Decimal          @default(0.0) @db.Decimal(12, 2)
  totalAmount                Decimal          @db.Decimal(12, 2)
  status                     BookingStatus    @default(PENDING_PAYMENT)
  refundRequired             Boolean          @default(false) // Đã thu tiền nhưng đơn bị hủy/không giữ được vé → cần hoàn tiền thủ công
  paymentMethod              String           @default("vnpay")
  fullName                   String
  email                      String
  phone                      String?
  note                       String?          @db.Text
  snapshotAt                 DateTime         @default(now())
  snapshotAttractionId       String?
  snapshotAttractionTitle    String           @default("")
  snapshotAttractionAddress  String           @default("")
  snapshotAttractionCity     String           @default("")
  snapshotAttractionDistrict String?
  snapshotAttractionImage    String?
  snapshotTicketName         String           @default("")
  snapshotTicketType         TicketType       @default(ADULT)
  snapshotTicketDescription  String?          @db.Text
  snapshotUnitPrice          Decimal          @default(0.0) @db.Decimal(12, 2)
  snapshotRefundPolicy       RefundPolicyType @default(NON_REFUNDABLE)
  snapshotRefundFeeRate      Decimal          @default(0.0) @db.Decimal(5, 2)
  snapshotRefundCutoffHours  Int              @default(24)
  snapshotVisitDate          DateTime?        @db.Date
  snapshotTimeSlotLabel      String?
  commissionRateSnapshot     Decimal          @default(0.10) @db.Decimal(5, 2)
  commissionAmountSnapshot   Decimal          @default(0.0) @db.Decimal(12, 2)
  partnerNetAmountSnapshot   Decimal          @default(0.0) @db.Decimal(12, 2)
  cancelledAt                DateTime?
  cancellationReason         String?          @db.Text
  cancellationSource         String?
  // Dữ liệu lịch sử có kiểm soát chỉ phục vụ mô hình dự báo. Không được xuất hiện
  // trong booking, KPI, báo cáo tài chính, đối soát hay trợ lý khách hàng.
  isForecastTrainingSample   Boolean          @default(false)
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt

  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservation        Reservation             @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  voucher            Voucher?                @relation(fields: [voucherId], references: [id])
  payments           Payment[]
  ticketInstances    TicketInstance[]
  refundRequests     RefundRequest[]
  refundTransactions RefundTransaction[]
  review             Review?
  settlementItems    PartnerSettlementItem[]
  liveTripItems      LiveTripItem[]
  smartQueueEntries  SmartQueueEntry[]

  @@index([userId])
  @@index([voucherId])
  @@index([status])
  @@index([snapshotAttractionId])
  @@index([snapshotVisitDate])
  @@index([isForecastTrainingSample])
  @@index([cancelledAt])
}

model PartnerSettlement {
  id                       String           @id @default(uuid())
  partnerId                String
  periodStart              DateTime         @db.Date
  periodEnd                DateTime         @db.Date
  status                   SettlementStatus @default(DRAFT)
  currency                 String           @default("VND")
  grossAmount              Decimal          @db.Decimal(14, 2)
  refundAmount             Decimal          @default(0.0) @db.Decimal(14, 2)
  netAmount                Decimal          @db.Decimal(14, 2)
  commissionAmount         Decimal          @db.Decimal(14, 2)
  payableAmount            Decimal          @db.Decimal(14, 2)
  bookingCount             Int
  bankNameSnapshot         String
  bankAccountNameSnapshot  String
  bankAccountLast4Snapshot String
  createdById              String?
  approvedById             String?
  approvedAt               DateTime?
  paidById                 String?
  paidAt                   DateTime?
  bankReference            String?          @unique
  cancelledById            String?
  cancelledAt              DateTime?
  cancellationReason       String?          @db.Text
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  partner PartnerProfile          @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  items   PartnerSettlementItem[]

  @@index([partnerId, periodStart, periodEnd])
  @@index([partnerId, status])
  @@index([status, createdAt])
  @@index([periodStart, periodEnd])
}

model PartnerSettlementItem {
  id               String    @id @default(uuid())
  settlementId     String
  bookingId        String
  grossAmount      Decimal   @db.Decimal(14, 2)
  refundAmount     Decimal   @default(0.0) @db.Decimal(14, 2)
  netAmount        Decimal   @db.Decimal(14, 2)
  commissionAmount Decimal   @db.Decimal(14, 2)
  payableAmount    Decimal   @db.Decimal(14, 2)
  releasedAt       DateTime?
  createdAt        DateTime  @default(now())

  settlement PartnerSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  booking    Booking           @relation(fields: [bookingId], references: [id], onDelete: Restrict)

  @@index([settlementId])
  @@index([bookingId, releasedAt])
}

model Payment {
  id                   String        @id @default(uuid())
  bookingId            String
  amount               Decimal       @db.Decimal(12, 2)
  paymentGateway       String
  transactionId        String?       @unique
  status               PaymentStatus @default(PENDING)
  expiresAt            DateTime?
  paidAt               DateTime?
  failureReason        String?
  isDuplicate          Boolean       @default(false)
  duplicateOfPaymentId String?
  rawResponse          Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  booking            Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  duplicateOfPayment Payment?            @relation("DuplicatePayment", fields: [duplicateOfPaymentId], references: [id], onDelete: SetNull)
  duplicatePayments  Payment[]           @relation("DuplicatePayment")
  refundTransactions RefundTransaction[]

  @@index([bookingId])
  @@index([status])
  @@index([expiresAt])
  @@index([isDuplicate])
}

model TicketInstance {
  id              String               @id @default(uuid())
  bookingId       String
  ticketProductId String
  qrCodeToken     String               @unique
  status          TicketInstanceStatus @default(VALID)
  checkedInAt     DateTime?
  checkedInById   String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  ticketProduct TicketProduct @relation(fields: [ticketProductId], references: [id], onDelete: Cascade)
  checkedInBy   User?         @relation("TicketCheckedInBy", fields: [checkedInById], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([ticketProductId])
  @@index([status])
  @@index([checkedInById])
  @@index([checkedInAt])
}

model Voucher {
  id            String              @id @default(uuid())
  code          String              @unique
  discountType  VoucherDiscountType
  discountValue Decimal             @db.Decimal(12, 2)
  maxDiscount   Decimal?            @db.Decimal(12, 2)
  minSpend      Decimal?            @db.Decimal(12, 2)
  expiryDate    DateTime
  isActive      Boolean             @default(true)
  usageLimit    Int?
  usedCount     Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  bookings Booking[]

  @@index([isActive, expiryDate])
}

enum RefundStatus {
  PENDING
  PROCESSING
  APPROVED
  REJECTED
}

enum RefundRequestType {
  CUSTOMER_CANCELLATION
  PARTNER_CANCELLATION
  SYSTEM_CANCELLATION
  DUPLICATE_PAYMENT
}

enum RefundTransactionStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  NEEDS_RECONCILIATION
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum SupportPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model RefundRequest {
  id                         String            @id @default(uuid())
  bookingId                  String
  requestKey                 String            @unique
  requestedById              String
  type                       RefundRequestType @default(CUSTOMER_CANCELLATION)
  mandatory                  Boolean           @default(false)
  reason                     String            @db.Text
  originalAmount             Decimal           @db.Decimal(12, 2)
  amount                     Decimal           @db.Decimal(12, 2)
  feeAmount                  Decimal           @default(0.0) @db.Decimal(12, 2)
  policySnapshot             RefundPolicyType?
  feeRateSnapshot            Decimal?          @db.Decimal(5, 2)
  bookingStatusBeforeRequest BookingStatus?
  status                     RefundStatus      @default(PENDING)
  staffNotes                 String?           @db.Text
  processedById              String?
  processingStartedAt        DateTime?
  createdAt                  DateTime          @default(now())
  processedAt                DateTime?
  updatedAt                  DateTime          @updatedAt

  booking            Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  refundTransactions RefundTransaction[]

  @@index([bookingId])
  @@index([status])
  @@index([requestedById])
  @@index([type, status])
}

model RefundTransaction {
  id                       String                  @id @default(uuid())
  bookingId                String
  paymentId                String?
  refundRequestId          String?
  gateway                  String                  @default("VNPAY")
  gatewayRequestId         String                  @unique
  transactionType          String?
  amount                   Decimal                 @db.Decimal(12, 2)
  status                   RefundTransactionStatus @default(PENDING)
  reason                   String?                 @db.Text
  rawRequest               Json?
  rawResponse              Json?
  gatewayResponseCode      String?
  gatewayTransactionStatus String?
  gatewayTransactionId     String?
  processedById            String?
  submittedAt              DateTime?
  reconciledAt             DateTime?
  processedAt              DateTime?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt

  booking       Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  payment       Payment?       @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  refundRequest RefundRequest? @relation(fields: [refundRequestId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([paymentId])
  @@index([refundRequestId])
  @@index([status])
}

model ScheduledJobLock {
  jobName     String    @id
  lockedBy    String?
  lockedUntil DateTime?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model SupportTicket {
  id               String          @id @default(uuid())
  userId           String
  bookingId        String?
  subject          String
  description      String          @db.Text
  status           SupportStatus   @default(OPEN)
  priority         SupportPriority @default(NORMAL)
  assignedToId     String?
  assignedAt       DateTime?
  firstRespondedAt DateTime?
  resolvedAt       DateTime?
  resolutionCode   String?
  resolutionNote   String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTo User?            @relation("SupportAssignedStaff", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages   SupportMessage[]

  @@index([userId])
  @@index([status])
  @@index([priority, status, createdAt])
  @@index([assignedToId, status])
}

model SupportMessage {
  id        String   @id @default(uuid())
  ticketId  String
  senderId  String
  message   String   @db.Text
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

// ============================================================
// Lưu lịch trình AI do người dùng generate và muốn giữ lại.
// data: JSON snapshot toàn bộ plan (cùng cấu trúc với response
//       của POST /api/ai/itinerary), không normalize thêm để
//       giữ đơn giản và không bị ảnh hưởng khi schema thay đổi.
// ============================================================
model SavedItinerary {
  id        String   @id @default(uuid())
  userId    String
  planId    String // client-generated ID (clientPlanId hoặc UUID)
  title     String
  data      Json // full plan snapshot
  criteria  Json? // tham số tạo lịch (city, days, budget, ...)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  liveTrip LiveTrip?

  @@unique([userId, planId])
  @@index([userId])
  @@index([createdAt])
}

enum LiveTripStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum LiveTripItemStatus {
  PLANNED
  AT_RISK
  REVISION_PROPOSED
  UPDATED
  COMPLETED
  SKIPPED
}

enum LiveTripProposalType {
  TIME_SHIFT
}

enum LiveTripProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  SUPERSEDED
}

enum SmartQueueStatus {
  WAITING
  READY
  ADMITTED
  CANCELLED
  EXPIRED
  NO_SHOW
}

enum SmartQueueMode {
  AUTO
  STAFF_CONTROLLED
}

enum LiveTripEventType {
  QUEUE_JOINED
  QUEUE_READY
  QUEUE_ADMITTED
  QUEUE_CANCELLED
  QUEUE_EXPIRED
  QUEUE_CALLED
  QUEUE_NO_SHOW
  QUEUE_PAUSED
  QUEUE_RESUMED
  AUTOPILOT_PROPOSED
  AUTOPILOT_ACCEPTED
  AUTOPILOT_REJECTED
  AUTOPILOT_EXPIRED
  ITEM_AT_RISK
  ITEM_RECOVERED
  ITEM_COMPLETED
  ITEM_SKIPPED
}

enum LiveTripEventSeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

// A materialized, operational version of a saved itinerary. The original
// SavedItinerary.data remains the customer's editable snapshot; these rows are
// used for safe, indexed live-trip queries and future revisions.
model LiveTrip {
  id               String         @id @default(uuid())
  userId           String
  savedItineraryId String         @unique
  title            String
  startDate        DateTime       @db.Date
  endDate          DateTime       @db.Date
  status           LiveTripStatus @default(ACTIVE)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedItinerary SavedItinerary        @relation(fields: [savedItineraryId], references: [id], onDelete: Cascade)
  items          LiveTripItem[]
  proposals      LiveTripProposal[]
  queueEntries   SmartQueueEntry[]
  events         LiveTripEvent[]
  simulations    AutopilotSimulation[]

  @@index([userId, status])
  @@index([startDate, endDate, status])
}

model LiveTripItem {
  id             String             @id @default(uuid())
  liveTripId     String
  attractionId   String?
  bookingId      String?
  dayIndex       Int
  orderIndex     Int
  scheduledStart DateTime
  scheduledEnd   DateTime?
  status         LiveTripItemStatus @default(PLANNED)
  snapshot       Json
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  liveTrip        LiveTrip           @relation(fields: [liveTripId], references: [id], onDelete: Cascade)
  attraction      Attraction?        @relation(fields: [attractionId], references: [id], onDelete: SetNull)
  booking         Booking?           @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  proposals       LiveTripProposal[]
  smartQueueEntry SmartQueueEntry?
  events          LiveTripEvent[]

  @@index([liveTripId, dayIndex, orderIndex])
  @@index([attractionId, scheduledStart])
  @@index([bookingId])
}

// Customer-confirmed operational revisions. activeKey is populated only while
// a proposal is PENDING, which provides a database guarantee of at most one
// active proposal per live-trip item while allowing complete history retention.
model LiveTripProposal {
  id             String                 @id @default(uuid())
  liveTripId     String
  liveTripItemId String
  activeKey      String?                @unique
  type           LiveTripProposalType
  status         LiveTripProposalStatus @default(PENDING)
  reasonCode     String
  rationale      String                 @db.Text
  originalStart  DateTime
  originalEnd    DateTime?
  proposedStart  DateTime
  proposedEnd    DateTime?
  snapshot       Json
  expiresAt      DateTime
  decidedAt      DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  liveTrip     LiveTrip     @relation(fields: [liveTripId], references: [id], onDelete: Cascade)
  liveTripItem LiveTripItem @relation(fields: [liveTripItemId], references: [id], onDelete: Cascade)

  @@index([liveTripId, status, createdAt])
  @@index([liveTripItemId, status])
  @@index([expiresAt, status])
}

// One durable virtual-queue record per live-trip item. The record is never
// deleted or reactivated, which enforces one enrolment per booked experience.
model SmartQueueEntry {
  id             String           @id @default(uuid())
  liveTripId     String
  liveTripItemId String           @unique
  userId         String
  attractionId   String
  bookingId      String
  visitDate      DateTime         @db.Date
  partySize      Int
  status         SmartQueueStatus @default(WAITING)
  joinedAt       DateTime         @default(now())
  readyAt        DateTime?
  admittedAt     DateTime?
  cancelledAt    DateTime?
  expiresAt      DateTime
  readyExpiresAt DateTime?
  calledAt       DateTime?
  noShowAt       DateTime?
  calledById     String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  liveTrip     LiveTrip     @relation(fields: [liveTripId], references: [id], onDelete: Cascade)
  liveTripItem LiveTripItem @relation(fields: [liveTripItemId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  attraction   Attraction   @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  calledBy     User?        @relation("SmartQueueCalledBy", fields: [calledById], references: [id], onDelete: SetNull)

  @@index([attractionId, visitDate, status, joinedAt])
  @@index([userId, status, updatedAt])
  @@index([bookingId, status])
  @@index([expiresAt, status])
}

// Operational policy is deliberately separate from attraction catalogue data:
// changing queue rules must not create a new product revision or affect ticket sales.
model SmartQueuePolicy {
  id                      String         @id @default(uuid())
  attractionId            String         @unique
  enabled                 Boolean        @default(true)
  mode                    SmartQueueMode @default(AUTO)
  openBeforeMinutes       Int            @default(120)
  readyGraceMinutes       Int            @default(10)
  maxReadyParties         Int            @default(3)
  maxActiveParties        Int            @default(100)
  fallbackThroughput15m   Int            @default(8)
  snapshotIntervalMinutes Int            @default(15)
  pausedAt                DateTime?
  pausedById              String?
  pauseReason             String?
  updatedById             String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  attraction Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  pausedBy   User?      @relation("SmartQueuePolicyPausedBy", fields: [pausedById], references: [id], onDelete: SetNull)
  updatedBy  User?      @relation("SmartQueuePolicyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([enabled, pausedAt])
}

// Immutable operational snapshots used for model training, backtesting and
// defence-demo evidence. observationKey makes the 15-minute worker idempotent.
model ArrivalObservation {
  id                    String    @id @default(uuid())
  observationKey        String    @unique
  attractionId          String
  bucketStart           DateTime
  bucketMinutes         Int       @default(15)
  capacity              Int       @default(0)
  bookedGuests          Int       @default(0)
  heldGuests            Int       @default(0)
  queueGuests           Int       @default(0)
  checkinsLast15Minutes Int       @default(0)
  showRate              Float     @default(0.9)
  pressureScore         Int       @default(0)
  weatherCode           String?
  calendarFeatures      Json?
  actualArrivalsNext15m Int?
  dataSource            String    @default("LIVE_OPERATIONAL")
  createdAt             DateTime  @default(now())
  evaluatedAt           DateTime?

  attraction  Attraction       @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  predictions LivePrediction[]

  @@index([attractionId, bucketStart])
  @@index([dataSource, actualArrivalsNext15m])
}

// Every prediction is auditable: model provenance, fallback status, confidence
// and feature contributions remain available after the UI has moved on.
model LivePrediction {
  id                   String    @id @default(uuid())
  attractionId         String
  observationId        String?
  predictionType       String
  horizonMinutes       Int       @default(15)
  predictedP50         Float
  predictedP90         Float
  confidence           String    @default("LOW")
  modelVersion         String
  trainingSource       String    @default("unknown")
  usedFallback         Boolean   @default(false)
  featureContributions Json?
  actualValue          Float?
  predictedAt          DateTime  @default(now())
  evaluatedAt          DateTime?

  attraction  Attraction          @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  observation ArrivalObservation? @relation(fields: [observationId], references: [id], onDelete: SetNull)

  @@index([attractionId, predictionType, predictedAt])
  @@index([modelVersion, predictedAt])
}

// A simulation is never a silent itinerary mutation. It records baseline,
// constraints and measurable impact before a customer accepts a proposal.
model AutopilotSimulation {
  id                    String   @id @default(uuid())
  liveTripId            String
  algorithmVersion      String
  baselineScore         Float
  optimizedScore        Float
  predictedMinutesSaved Int      @default(0)
  protectedBookingCount Int      @default(0)
  proposalCount         Int      @default(0)
  constraints           Json
  result                Json
  createdAt             DateTime @default(now())

  liveTrip LiveTrip @relation(fields: [liveTripId], references: [id], onDelete: Cascade)

  @@index([liveTripId, createdAt])
}

// Durable event history powers the in-app activity feed and makes every
// Autopilot/SmartQueue decision explainable during operations and assessment.
model LiveTripEvent {
  id             String                @id @default(uuid())
  liveTripId     String
  liveTripItemId String?
  userId         String
  type           LiveTripEventType
  severity       LiveTripEventSeverity @default(INFO)
  title          String
  message        String                @db.Text
  data           Json?
  createdAt      DateTime              @default(now())

  liveTrip     LiveTrip      @relation(fields: [liveTripId], references: [id], onDelete: Cascade)
  liveTripItem LiveTripItem? @relation(fields: [liveTripItemId], references: [id], onDelete: SetNull)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([liveTripId, createdAt])
  @@index([userId, createdAt])
  @@index([liveTripItemId, createdAt])
}

// ============================================================
// AI Revenue Forecasting
// ------------------------------------------------------------
// Kết quả dự báo doanh thu thuần được ghi nhận theo điểm tham quan + ngày
// sử dụng dịch vụ. Node backend tổng hợp cùng một định nghĩa doanh thu với
// báo cáo đối tác, gọi ml-service và lưu kết quả gần nhất để:
//   - Không phải gọi lại ml-service mỗi lần Admin/Partner xem dashboard
//   - Công khai phiên bản/phương pháp dự báo và mức độ tin cậy
//   - Đối chiếu actualRevenue sau ngày sử dụng để theo dõi chất lượng
// Quyền xem: chỉ ADMIN (toàn nền tảng) và PARTNER (chỉ attraction của
// chính mình) - STAFF không có quyền xem dự báo doanh thu.
// ============================================================
model RevenueForecast {
  id               String   @id @default(uuid())
  attractionId     String
  forecastDate     DateTime @db.Date // Ngày được dự báo doanh thu
  predictedRevenue Decimal  @db.Decimal(14, 2) // Doanh thu thuần dự kiến trước hoa hồng
  predictedTickets Int      @default(0)
  confidenceLower  Decimal? @db.Decimal(14, 2) // Cận dưới khoảng tin cậy
  confidenceUpper  Decimal? @db.Decimal(14, 2) // Cận trên khoảng tin cậy
  actualRevenue    Decimal? @db.Decimal(14, 2) // Doanh thu thuần thực tế sau khi ngày tham quan kết thúc
  modelVersion     String // Phiên bản model hoặc phương pháp fallback
  trainingSource   String   @default("unknown") // real_booking_history, demo_booking_history hoặc historical_baseline
  usedFallback     Boolean  @default(false)
  historyDays      Int      @default(0)
  observedDays     Int      @default(0)
  sampleBookings   Int      @default(0)
  generatedAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  attraction Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)

  @@unique([attractionId, forecastDate])
  @@index([attractionId])
  @@index([forecastDate])
  @@index([generatedAt])
}
