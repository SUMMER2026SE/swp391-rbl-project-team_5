{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.js",
  "scripts": {
    "predev": "prisma generate",
    "dev": "nodemon src/server.js",
    "prestart": "prisma generate",
    "start": "node src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:seed:real": "node prisma/seed-real.js",
    "db:seed:images": "node prisma/seed-images.js",
    "db:seed:forecast-demo": "node scripts/seed_forecast_demo_history.js",
    "demo:prepare": "node scripts/seed_defense_demo.js --reset --confirm-local-demo",
    "demo:check": "node scripts/seed_defense_demo.js --check",
    "demo:smoke": "node scripts/smoke_defense_demo.js",
    "demo:llm-check": "node scripts/check_demo_llm.js",
    "db:enrich": "node prisma/enrich-content.js",
    "create-admin": "node create-admin.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fontsource/noto-sans": "^5.2.10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.2.0",
    "jsonrepair": "^3.14.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.19.0",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "supertest": "^6.3.3"
  },
  "overrides": {
    "@prisma/dev": "0.24.14"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/controllers/**/*.js",
      "src/utils/**/*.js"
    ]
  }
