# ============================================
# VietTicket Travel — ml-service (AI Revenue Forecasting)
# Sao chép file này thành .env rồi điền giá trị thật
# ============================================

# Cổng chạy FastAPI (uvicorn)
PORT=8000

# Khóa bí mật dùng chung với Node backend để bảo vệ endpoint /forecast
# (Node gửi header "x-ml-api-key" khi gọi ML service).
# Để trống ở local nếu không cần bảo vệ.
ML_SERVICE_API_KEY=""

# Đường dẫn thư mục lưu model đã train (joblib) + metadata.json
MODEL_DIR="./models"

# Phiên bản model hiện tại (đổi khi thay đổi kiến trúc/feature đáng kể)
MODEL_VERSION="rf_xgb_ensemble_v1"
