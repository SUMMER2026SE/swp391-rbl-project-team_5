# Local development defaults. Keep API same-origin so auth cookies work with
# either localhost or 127.0.0.1 while Vite proxies /api to the backend.
VITE_API_URL=/api
VITE_API_PROXY_TARGET=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000
VITE_DEV_HOST=localhost
VITE_DEV_PORT=5173
VITE_GOOGLE_CLIENT_ID=
VITE_MAPTILER_KEY=
